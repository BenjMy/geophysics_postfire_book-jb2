pe":"heading","depth":3,"position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"Pseudosection Visualisation","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"tWtUv71Oy6"}],"identifier":"pseudosection-visualisation","label":"Pseudosection Visualisation","html_id":"pseudosection-visualisation","implicit":true,"key":"xjtxgbimeW"},{"type":"paragraph","position":{"start":{"line":107,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"A ","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"jeYcfbXQhn"},{"type":"strong","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"children":[{"type":"text","value":"pseudosection","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"EZX8T6yjtJ"}],"key":"NkyXZkEnof"},{"type":"text","value":" plots apparent resistivity against electrode mid-point and pseudo-depth.\nIt is a qualitative picture of the data — not a true depth section.","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"dHnCuwRUAj"}],"key":"Hg3uCNf4dJ"}],"key":"x1mhPtX6ja"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# After loading data:\n# k.showPseudoSection()\n\n# Simulated pseudosection for illustration\nnp.random.seed(42)\nn_levels = 8\nn_points = 40\n\nfig, ax = plt.subplots(figsize=(11, 5))\n\nx_mid  = np.linspace(0, 47, n_points)\ndepths = np.arange(1, n_levels + 1) * 1.5\n\ncmap = plt.cm.RdYlBu_r\nnorm = plt.Normalize(vmin=10, vmax=500)\n\nfor depth in depths:\n    rho_a = np.exp(np.random.normal(loc=4.5, scale=0.4, size=n_points))\n    sc = ax.scatter(x_mid, -np.full_like(x_mid, depth),\n                    c=rho_a, cmap=cmap, norm=norm, s=60, marker='v')\n\ncb = fig.colorbar(sc, ax=ax, pad=0.02)\ncb.set_label(\"Apparent Resistivity (Ω·m)\")\nax.set_xlabel(\"Mid-point position (m)\")\nax.set_ylabel(\"Pseudo-depth (m)\")\nax.set_title(\"Synthetic Pseudosection — Wenner Array\")\nax.grid(True, alpha=0.2)\nplt.tight_layout()\nplt.show()","key":"lhcB6RZiV0"},{"type":"outputs","id":"dXXeBFpmIuDG5Gpeb1WIZ","children":[],"key":"oqQMTVaktX"}],"key":"Pm3mBVj7Su"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":142,"column":1},"end":{"line":142,"column":1}},"key":"jKF39DnKci"},{"type":"heading","depth":3,"position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"children":[{"type":"text","value":"Running an Inversion","position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"key":"tVCj79IAWg"}],"identifier":"running-an-inversion","label":"Running an Inversion","html_id":"running-an-inversion","implicit":true,"key":"cc20HVhtAo"}],"key":"KnZ66MczLe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# After creating the survey and mesh:\n#\n# k.createMesh(typ='trian')        # triangular mesh\n# k.param['a_wgt'] = 0.01         # regularisation weight\n# k.invert()                       # run R2\n# k.showResults()                  # display inverted section\n#\n# The inversion minimises:\n#   Φ = ‖Wd(d_obs − d_pred)‖² + λ‖Wm m‖²\n# where λ is the regularisation parameter (trade-off).\n\nprint(\"Inversion parameters overview:\")\nparams = {\n    \"a_wgt\"    : \"Absolute data weight (noise floor)\",\n    \"b_wgt\"    : \"Relative data weight\",\n    \"alpha_s\"  : \"Smoothness regularisation weight\",\n    \"max_iter\" : \"Maximum inversion iterations\",\n}\nfor k_p, desc in params.items():\n    print(f\"  {k_p:12s}  →  {desc}\")","key":"nRzIwzuKDt"},{"type":"outputs","id":"emQ3_hozlL9wmhk058s8k","children":[],"key":"s98FWh9ECy"}],"key":"kmMRZismYK"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"key":"khhDP0K5xL"},{"type":"heading","depth":3,"position":{"start":{"line":171,"column":1},"end":{"line":171,"column":1}},"children":[{"type":"text","value":"Synthetic Inverted Section","position":{"start":{"line":171,"column":1},"end":{"line":171,"column":1}},"key":"pzQT892Pqc"}],"identifier":"synthetic-inverted-section","label":"Synthetic Inverted Section","html_id":"synthetic-inverted-section","implicit":true,"key":"z3K8qr9KD9"}],"key":"br5PHpXc4k"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from matplotlib.colors import LogNorm\n\n# Synthetic 2-D resistivity model for illustration\nnx, nz = 80, 30\nx = np.linspace(0, 47, nx)\nz = np.linspace(0, -15, nz)\nX, Z = np.meshgrid(x, z)\n\n# Background + conductive anomaly + resistive layer\nrho = np.full((nz, nx), 150.0)\nrho[Z > -8] = 80      # shallow moist layer\nrho[(Z > -12) & (Z < -8) & (X > 15) & (X < 30)] = 12   # conductive body\nrho[Z < -13] = 800    # resistive bedrock\n\nfig, ax = plt.subplots(figsize=(11, 4))\nim = ax.pcolormesh(X, Z, rho, cmap='RdYlBu_r', norm=LogNorm(vmin=10, vmax=1000), shading='auto')\ncb = fig.colorbar(im, ax=ax, pad=0.02)\ncb.set_label(\"Resistivity (Ω·m)\")\nax.set_xlabel(\"Distance (m)\")\nax.set_ylabel(\"Depth (m)\")\nax.set_title(\"Synthetic Inverted Resistivity Section\")\nplt.tight_layout()\nplt.show()","key":"RuRpVbTxdU"},{"type":"outputs","id":"QucdE3VeizDGjtEck5-Io","children":[],"key":"KM0f82nA9l"}],"key":"YhExlVQFaA"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":199,"column":1},"end":{"line":199,"column":1}},"key":"i2R9BqOKQa"},{"type":"heading","depth":3,"position":{"start":{"line":201,"column":1},"end":{"line":201,"column":1}},"children":[{"type":"text","value":"Interpretation Guide","position":{"start":{"line":201,"column":1},"end":{"line":201,"column":1}},"key":"sUj4t1Cj8l"}],"identifier":"interpretation-guide","label":"Interpretation Guide","html_id":"interpretation-guide","implicit":true,"key":"tESJJAvx4p"},{"type":