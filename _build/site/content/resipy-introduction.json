"label":"Pseudosection Visualisation","html_id":"pseudosection-visualisation","implicit":true,"key":"EHkX3YmYuT"},{"type":"paragraph","position":{"start":{"line":108,"column":1},"end":{"line":109,"column":1}},"children":[{"type":"text","value":"A ","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"gaQ1cTqgSN"},{"type":"strong","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"pseudosection","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"cPyZ1Ef8zy"}],"key":"YcSTT1Al3B"},{"type":"text","value":" plots apparent resistivity against electrode mid-point and pseudo-depth.\nIt is a qualitative picture of the data — not a true depth section.","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"v4OMWcYQ5V"}],"key":"pzB40MRPto"}],"key":"RBoqbQvof6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# After loading data:\n# k.showPseudoSection()\n\n# Simulated pseudosection for illustration\nnp.random.seed(42)\nn_levels = 8\nn_points = 40\n\nfig, ax = plt.subplots(figsize=(11, 5))\n\nx_mid  = np.linspace(0, 47, n_points)\ndepths = np.arange(1, n_levels + 1) * 1.5\n\ncmap = plt.cm.RdYlBu_r\nnorm = plt.Normalize(vmin=10, vmax=500)\n\nfor depth in depths:\n    rho_a = np.exp(np.random.normal(loc=4.5, scale=0.4, size=n_points))\n    sc = ax.scatter(x_mid, -np.full_like(x_mid, depth),\n                    c=rho_a, cmap=cmap, norm=norm, s=60, marker='v')\n\ncb = fig.colorbar(sc, ax=ax, pad=0.02)\ncb.set_label(\"Apparent Resistivity (Ω·m)\")\nax.set_xlabel(\"Mid-point position (m)\")\nax.set_ylabel(\"Pseudo-depth (m)\")\nax.set_title(\"Synthetic Pseudosection — Wenner Array\")\nax.grid(True, alpha=0.2)\nplt.tight_layout()\nplt.show()","key":"sMGiYE0lyr"},{"type":"outputs","id":"XoA_RpEBWN0K6oQp-IFxV","children":[],"key":"u0K9C0k8Dy"}],"key":"smXPYSEYA7"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"key":"l1rxH1Jy2v"},{"type":"heading","depth":3,"position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"children":[{"type":"text","value":"Running an Inversion","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"HZ08HirCbW"}],"identifier":"running-an-inversion","label":"Running an Inversion","html_id":"running-an-inversion","implicit":true,"key":"VuKnUb45aP"}],"key":"nc5NuVBg02"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# After creating the survey and mesh:\n#\n# k.createMesh(typ='trian')        # triangular mesh\n# k.param['a_wgt'] = 0.01         # regularisation weight\n# k.invert()                       # run R2\n# k.showResults()                  # display inverted section\n#\n# The inversion minimises:\n#   Φ = ‖Wd(d_obs − d_pred)‖² + λ‖Wm m‖²\n# where λ is the regularisation parameter (trade-off).\n\nprint(\"Inversion parameters overview:\")\nparams = {\n    \"a_wgt\"    : \"Absolute data weight (noise floor)\",\n    \"b_wgt\"    : \"Relative data weight\",\n    \"alpha_s\"  : \"Smoothness regularisation weight\",\n    \"max_iter\" : \"Maximum inversion iterations\",\n}\nfor k_p, desc in params.items():\n    print(f\"  {k_p:12s}  →  {desc}\")","key":"WpKGDmVZav"},{"type":"outputs","id":"pWaQ2JcKMOY5bMDqycnd2","children":[],"key":"RuBKE98M0Q"}],"key":"KViHcNMpUg"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":170,"column":1},"end":{"line":170,"column":1}},"key":"fS5stqRkvb"},{"type":"heading","depth":3,"position":{"start":{"line":172,"column":1},"end":{"line":172,"column":1}},"children":[{"type":"text","value":"Synthetic Inverted Section","position":{"start":{"line":172,"column":1},"end":{"line":172,"column":1}},"key":"bXnirUF29p"}],"identifier":"synthetic-inverted-section","label":"Synthetic Inverted Section","html_id":"synthetic-inverted-section","implicit":true,"key":"dhQ2njt15g"}],"key":"Ta1mCinRhJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from matplotlib.colors import LogNorm\n\n# Synthetic 2-D resistivity model for illustration\nnx, nz = 80, 30\nx = np.linspace(0, 47, nx)\nz = np.linspace(0, -15, nz)\nX, Z = np.meshgrid(x, z)\n\n# Background + conductive anomaly + resistive layer\nrho = np.full((nz, nx), 150.0)\nrho[Z > -8] = 80      # shallow moist layer\nrho[(Z > -12) & (Z < -8) & (X > 15) & (X < 30)] = 12   # conductive body\nrho[Z < -13] = 800    # resistive bedrock\n\nfig, ax = plt.subplots(figsize=(11, 4))\nim = ax.pcolormesh(X, Z, rho, cmap='RdYlBu_r', norm=LogNorm(vmin=10, vmax=1000), shading='auto')\ncb = fig.colorbar(im, ax=ax, pad=0.02)\ncb.set_label(\"Resistivity (Ω·m)\")\nax.set_xlabel(\"Distance (m)\")\nax.set_ylabel(\"Depth (m)\")\nax.set_title(\"Synthetic Inverted Resistivity Section\")\nplt.tight_layout()\nplt.show()","key":"G85OorySG7"},{"type":"outputs","id":"FSyR_ZaPFCICD47wzj51T","children":[],"key":"Wj4m6vJx4X"}],"key":"U9wt2NP8Mb"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":200,"column":1},"end":{"line":200,"column":1}},"key":"oKUnn8RxTp"},{"type":"heading","depth":3,"position":{"start":{"line":202,"column":1},"end":{"line":202,"column":1}},"children":[{"type":"text","value":"Interpretation Guide","position":{"start":{"line":202,"column":1},"end":{"line":202,"column":1}},"key":"qKu32ZeyDr"}],"identifier":"interpretation-guide","label":"Interpretation Guide","html_id":"interpretation-guide","implicit":true,"key":"VBfEycjjRk"},{"type":"container","kind":"table","children":[{"type":"table","children":[{"type":"tableRow","children":[{"type":"tableCell","header":true,"children":[{"type":"paragraph","children":[{"type":"text","value":"Feature","position":{"start":{"line":208,"column":1},"end":{"line":208,"column":1}},"key":"DlWg7boFgy"}