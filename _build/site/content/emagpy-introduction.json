()\nplt.show()","key":"teuEYQw0RE"},{"type":"outputs","id":"t1A3quMv4EP_LbGzmRTpv","children":[],"key":"BZIU3UbBGU"}],"key":"MFrSwrypqZ"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"r0DWfpg5Av"},{"type":"heading","depth":3,"position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"Creating a Problem","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"UOJ9hWGPa0"}],"identifier":"creating-a-problem","label":"Creating a Problem","html_id":"creating-a-problem","implicit":true,"key":"Nj7g83Mkx4"}],"key":"d6y4uhB1I3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from emagpy import Problem\n\nk = Problem()\nprint(\"emagpy Problem created successfully!\")","key":"Uip2rwaM37"},{"type":"outputs","id":"xd-cwo3KrPW4-1wYuUP2t","children":[],"key":"N5h5pGkilF"}],"key":"Di4i7jePGt"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"fHUejRnsdb"},{"type":"heading","depth":3,"position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"Importing Data","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"ervKc5smMo"}],"identifier":"importing-data","label":"Importing Data","html_id":"importing-data","implicit":true,"key":"TqBqp25H5r"}],"key":"l43ezqLKb5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load a CSV data file\n# k.importData('data/sample_em/survey.csv')\n\n# Expected CSV format:\nprint(\"Expected CSV columns:\")\nheader = \"x, y, ECa_HCP_0.32m, ECa_HCP_0.71m, ECa_HCP_1.18m, ECa_VCP_0.32m\"\nprint(\" \", header)\nprint(\"  0.0, 0.0, 35.2, 48.1, 62.4, 28.9\")\nprint(\"  0.5, 0.0, 36.8, 49.3, 63.1, 29.5\")\nprint(\"  ...\")","key":"q