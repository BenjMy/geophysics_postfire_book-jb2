mgFhC20NX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from emagpy import Problem\n\nk = Problem()\nprint(\"emagpy Problem created successfully!\")","key":"hbDtuYY2Tl"},{"type":"outputs","id":"SX-ZBk_ShA5mUgNxqQJpl","children":[],"key":"cLfXqafPJG"}],"key":"DZLK7oSVix"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"rrJc1HdaHe"},{"type":"heading","depth":3,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Importing Data","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"I4WtHd2hKe"}],"identifier":"importing-data","label":"Importing Data","html_id":"importing-data","implicit":true,"key":"OnYhR1yEVE"}],"key":"rt4YAgCQBt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load a CSV data file\n# k.importData('data/sample_em/survey.csv')\n\n# Expected CSV format:\nprint(\"Expected CSV columns:\")\nheader = \"x, y, ECa_HCP_0.32m, ECa_HCP_0.71m, ECa_HCP_1.18m, ECa_VCP_0.32m\"\nprint(\" \", header)\nprint(\"  0.0, 0.0, 35.2, 48.1, 62.4, 28.9\")\nprint(\"  0.5, 0.0, 36.8, 49.3, 63.1, 29.5\")\nprint(\"  ...\")","key":"jAjOdK0u4b"},{"type":"outputs","id":"IxI9h85nwy2OkYytEQAGQ","children":[],"key":"dS8vpRegyn"}],"key":"fuYztnxlwG"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"Vw31OKmu3Y"},{"type":"heading","depth":3,"position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"Synthetic ECa Map","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"B7WhzprZg9"}],"identifier":"synthetic-eca-map","label":"Synthetic ECa Map","html_id":"synthetic-eca-map","implicit":true,"key":"RjRq70Kkqr"}],"key":"OUhgIQGUsa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"np.random.seed(7)\n\n# Simulate a survey grid (50 × 20 m)\nx = np.linspace(0, 50, 60)\ny = np.linspace(0, 20, 25)\nX, Y = np.meshgrid(x, y)\n\n# Synthetic ECa: background + conductive anomaly\nECa = 25 + 20 * np.exp(-((X - 25)**2 / 60 + (Y - 10)**2 / 15))\nECa += np.random.normal(0, 1.5, ECa.shape)  # add noise\n\nfig, ax = plt.subplots(figsize=(11, 4))\nim = ax.pcolormesh(X, Y, ECa, cmap='viridis', shading='auto')\ncb = fig.colorbar(im, ax=ax, pad=0.02)\ncb.set_label(\"ECa (mS/m)\")\nax.set_xlabel(\"Easting (m)\")\nax.set_ylabel(\"Northing (m)\")\nax.set_title(\"Synthetic ECa map — HCP 1.18 m coil\")\nax.set_aspect('equal')\nplt.tight_layout()\nplt.show()","key":"aJM9uD1i0d"},{"type":"outputs","id":"FRBGssGEN5yyIdepwtblU","children":[],"key":"Z3zM5vwF8q"}],"key":"s0u8HsmpmF"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"jhAeZXN3Ke"},{"type":"heading","depth":3,"position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"1-D Lateral Inversion","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"tLWtV3Kw7l"}],"identifier":"id-1-d-lateral-inversion","label":"1-D Lateral Inversion","html_id":"id-1-d-lateral-inversion","implicit":true,"key":"bRqJ22Mcth"},{"type":"paragraph","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"emagpy inverts each measurement position independently using a layered-earth model.","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"sPK1rZfnBn"}],"key":"UvAfbFuC91"}],"key":"IWoWpXSVQi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# After importing real data:\n#\n# k.setInit(conds0=[30, 30, 30],    # initial conductivity (mS/m) per layer\n#           depths0=[0.5, 1.5])     # layer depths (m)\n# k.invertGN()                      # Gauss-Newton inversion\n# k.showResults()                   # plot conductivity maps per layer\n\n# Conceptual layered model illustration\nlayer_depths  = [0,    0.5,  1.5,  4.0]\nlayer_conds   = [20,   55,   30,   15]   # mS/m\nlayer_labels  = [\"Topsoil\", \"Clay lens\", \"Sandy subsoil\", \"Bedrock\"]\ncolors        = ['#c4a35a', '#8b4513', '#d2b48c', '#808080']\n\nfig, ax = plt.subplots(figsize=(5, 6))\nfor i in range(len(layer_conds)):\n    top    = -layer_depths[i]\n    bottom = -layer_depths[i+1] if i+1 < len(layer_depths) else -5.5\n    rect = plt.Rectangle((0, bottom), layer_conds[i], top - bottom,\n                          color=colors[i], alpha=0.85, edgecolor='k', linewidth=0.8)\n    ax.add_patch(rect)\n    ax.text(layer_conds[i] / 2, (top + bottom) / 2,\n            f\"{layer_labels[i]}\\n{layer_conds[i]} mS/m\",\n            ha='center', va='center', fontsize=9)\n\nax.set_xlim(0, 70)\nax.set_ylim(-5.5, 0.2)\nax.set_xlabel(\"Electrical conductivity (mS/m)\")\nax.set_ylabel(\"Depth (m)\")\nax.set_title(\"Example 1-D inverted model\")\nax.grid(axis='x', alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"kAIzFIHQ77"},{"type":"outputs","id":"v0mZhGVBeor5KG08hkc0i","children":[],"key":"miTb0Mwqel"}],"key":"iyoyHVycXn"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"key":"EWRC6Ys8Tv"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Summary","position":{"start":{"line":125,"column":1},"end":{"line":125,"column":1}},"key":"knYYvMkihu"}],"key":"xOMZqwSd5T"},{"type":"paragraph","position":{"start":{"line":127,"column":1},"end":{"line":127,"column":1}},"children":[{"type":"text","value":"You have learned:","position":{"start":{"line":127,"column":1},"end":{"line":127,"column":1}},"key":"r67TT9zmK8"}],"key":"b20KfAOz2c"},{"type":"list","ordered":false,"