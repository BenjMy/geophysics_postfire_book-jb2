()\nplt.show()","key":"qGOi50L5St"},{"type":"outputs","id":"t1A3quMv4EP_LbGzmRTpv","children":[],"key":"kNZqjziE4o"}],"key":"trlAGUN92V"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"Aj6BHNsq0K"},{"type":"heading","depth":3,"position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"Creating a Problem","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"FnbyoxigFH"}],"identifier":"creating-a-problem","label":"Creating a Problem","html_id":"creating-a-problem","implicit":true,"key":"RW3d5qWBq1"}],"key":"e8HNBU5FAe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from emagpy import Problem\n\nk = Problem()\nprint(\"emagpy Problem created successfully!\")","key":"ZKpPUubRVC"},{"type":"outputs","id":"xd-cwo3KrPW4-1wYuUP2t","children":[],"key":"u38AezVOhf"}],"key":"v71m40SkIl"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"ZQoxpdbvMg"},{"type":"heading","depth":3,"position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"Importing Data","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"ixhvpVUNLa"}],"identifier":"importing-data","label":"Importing Data","html_id":"importing-data","implicit":true,"key":"UljxUsLa80"}],"key":"YSQ1ry4KQK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load a CSV data file\n# k.importData('data/sample_em/survey.csv')\n\n# Expected CSV format:\nprint(\"Expected CSV columns:\")\nheader = \"x, y, ECa_HCP_0.32m, ECa_HCP_0.71m, ECa_HCP_1.18m, ECa_VCP_0.32m\"\nprint(\" \", header)\nprint(\"  0.0, 0.0, 35.2, 48.1, 62.4, 28.9\")\nprint(\"  0.5, 0.0, 36.8, 49.3, 63.1, 29.5\")\nprint(\"  ...\")","key":"ZX9QstlEml"},{"type":"outputs","id":"65ccrODe3IDGD_Xj12aUz","children":[],"key":"k0cmK8Y11w"}],"key":"tlormVGiaf"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":96,"column":1},"end":{"line":96,"column":1}},"key":"w2CNJ8tOW5"},{"type":"heading","depth":3,"position":{"start":{"line":98,"column":1},"end":{"line":98,"column":1}},"children":[{"type":"text","value":"Synthetic ECa Map","position":{"start":{"line":98,"column":1},"end":{"line":98,"column":1}},"key":"Wm5shaA0jj"}],"identifier":"synthetic-eca-map","label":"Synthetic ECa Map","html_id":"synthetic-eca-map","implicit":true,"key":"fpv9opaoDL"}],"key":"KBm14yx2T8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"np.random.seed(7)\n\n# Simulate a survey grid (50 × 20 m)\nx = np.linspace(0, 50, 60)\ny = np.linspace(0, 20, 25)\nX, Y = np.meshgrid(x, y)\n\n# Synthetic ECa: background + conductive anomaly\nECa = 25 + 20 * np.exp(-((X - 25)**2 / 60 + (Y - 10)**2 / 15))\nECa += np.random.normal(0, 1.5, ECa.shape)  # add noise\n\nfig, ax = plt.subplots(figsize=(11, 4))\nim = ax.pcolormesh(X, Y, ECa, cmap='viridis', shading='auto')\ncb = fig.colorbar(im, ax=ax, pad=0.02)\ncb.set_label(\"ECa (mS/m)\")\nax.set_xlabel(\"Easting (m)\")\nax.set_ylabel(\"Northing (m)\")\nax.set_title(\"Synthetic ECa map — HCP 1.18 m coil\")\nax.set_aspect('equal')\nplt.tight_layout()\nplt.show()","key":"tk4qEsj2Uq"},{"type":"outputs","id":"hO-yPF5MYcl1_3bPZoHkn","children":[],"key":"P6UcH7uzLA"}],"key":"SIsLeCm2Uj"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"v5hZyizxWD"},{"type":"heading","depth":3,"position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"children":[{"type":"text","value":"1-D Lateral Inversion","position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"key":"wMVia6YNLW"}],"identifier":"id-1-d-lateral-inversion","label":"1-D Lateral Inversion","html_id":"id-1-d-lateral-inversion","implicit":true,"key":"qnt4SMWoPT"},{"type":"paragraph","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"children":[{"type":"text","value":"emagpy inverts each measurement position independently using a layered-earth model.","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"key":"qBZXMqSQkZ"}],"key":"SW9MvraTBL"}],"key":"KR3fVCK53O"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# After importing real data:\n#\n# k.setInit(conds0=[30, 30, 30],    # initial conductivity (mS/m) per layer\n#           depths0=[0.5, 1.5])     # layer depths (m)\n# k.invertGN()                      # Gauss-Newton inversion\n# k.showResults()                   # plot conductivity maps per layer\n\n# Conceptual layered model illustration\nlayer_depths  = [0,    0.5,  1.5,  4.0]\nlayer_conds   = [20,   55,   30,   15]   # mS/m\nlayer_labels  = [\"Topsoil\", \"Clay lens\", \"Sandy subsoil\", \"Bedrock\"]\ncolors        = ['#c4a35a', '#8b4513', '#d2b48c', '#808080']\n\nfig, ax = plt.subplots(figsize=(5, 6))\nfor i in range(len(layer_conds)):\n    top    = -layer_depths[i]\n    bottom = -layer_depths[i+1] if i+1 < len(layer_depths) else -5.5\n    rect = plt.Rectangle((0, bottom), layer_conds[i], top - bottom,\n                          color=colors[i], alpha=0.85, edgecolor='k', linewidth=0.8)\n    ax.add_patch(rect)\n    ax.text(layer_conds[i] / 2, (top + bottom) / 2,\n            f\"{layer_labels[i]}\\n{layer_conds[i]} mS/m\",\n            ha='center', va='center', fontsize=9)\n\nax.set_xlim(0, 70)\nax.set_ylim(-5.5, 0.2)\nax.set_xlabel(\"Electrical conductivity (mS/m)\")\nax.set_ylabel(\"Depth (m)\")\nax.set_title(\"Example 1-D inverted model\")\nax.grid(axis='x', alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"Dzm4IoQHzT"},{"type":"outputs","id":"IxuoYR4VnZygu45UI8MQc","children":[],"key":"w5YuZkvwuO"}],"k