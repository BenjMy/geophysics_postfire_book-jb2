" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:2.0463em;vertical-align:-0.686em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.00773em;\">R</span><span class=\"mord\"><span class=\"mopen nulldelimiter\"></span><span class=\"mfrac\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:1.3603em;\"><span style=\"top:-2.314em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\">L</span></span></span><span style=\"top:-3.23em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"frac-line\" style=\"border-bottom-width:0.04em;\"></span></span><span style=\"top:-3.677em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\">A</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.686em;\"><span></span></span></span></span></span><span class=\"mclose nulldelimiter\"></span></span></span></span></span></span>","enumerator":"3","key":"JgEZQoVPEg"}],"key":"oIrxhKfQp4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nimport ipywidgets as widgets\nfrom IPython.display import display\n\ndef resistance(rho, L, A):\n    \"\"\"Ohm's Law: resistance of a homogeneous cylinder.\"\"\"\n    return rho * L / A\n\n# Example: a 1 m³ cube of moist loam (rho ≈ 50 Ω·m)\nrho_loam = 50   # Ω·m\nR = resistance(rho_loam, L=1.0, A=1.0)\nprint(f\"Resistance of 1 m³ loam cube : {R:.1f} Ω\")","visibility":"hide","key":"drxrYa7A3M"},{"type":"output","id":"9kX3EWVfWKB0j4AAlmxtb","data":[],"visibility":"show","key":"i0i9HhSKbf"}],"data":{"tags":[]},"visibility":"show","key":"p5yIgck37T"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"🎛️ Interactive Explorer — Ohm’s Law","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"GoN7IQyTxr"}],"identifier":"id-interactive-explorer-ohms-law","label":"🎛️ Interactive Explorer — Ohm’s Law","html_id":"id-interactive-explorer-ohms-law","implicit":true,"key":"XQVS1q7o4D"},{"type":"paragraph","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"children":[{"type":"text","value":"Adjust resistivity, length and cross-section to see how resistance changes:","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"key":"ZllG6fC2Yk"}],"key":"jiX46ApRAU"}],"key":"K4ieDEAuAV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def ohm_widget():\n    rho_slider = widgets.FloatLogSlider(\n        value=50, base=10, min=0, max=6,\n        step=0.05, description='ρ (Ω·m)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    L_slider = widgets.FloatSlider(\n        value=1.0, min=0.1, max=10.0, step=0.1,\n        description='L (m)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    A_slider = widgets.FloatSlider(\n        value=1.0, min=0.01, max=5.0, step=0.01,\n        description='A (m²)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    out = widgets.Output()\n\n    def update(change=None):\n        R = rho_slider.value * L_slider.value / A_slider.value\n        sigma = 1 / rho_slider.value\n        with out:\n            out.clear_output(wait=True)\n            print(f\"  Resistance  R = {R:.4f} Ω\")\n            print(f\"  Conductivity σ = {sigma:.6f} S/m\")\n\n    rho_slider.observe(update, names='value')\n    L_slider.observe(update, names='value')\n    A_slider.observe(update, names='value')\n    update()\n\n    display(widgets.VBox([\n        widgets.HTML(\"<b>Ohm's Law — R = ρ · L / A</b>\"),\n        rho_slider, L_slider, A_slider, out\n    ]))\n\nohm_widget()","visibility":"hide","key":"adQrsZcJmk"},{"type":"output","id":"OusnoSwqj84C6LlsFSCNZ","data":[],"visibility":"show","key":"VheGARUbUI"}],"data":{"tags":[]},"visibility":"show","key":"Q3k8rEpMtF"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"N4ATLkfe4S"},{"type":"heading","depth":2,"position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"Typical Resistivity Values","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"MnamiQvpWY"}],"identifier":"typical-resistivity-values","label":"Typical Resistivity Values","html_id":"typical-resistivity-values","implicit":true,"key":"XBEAWA9a97"}],"key":"FE8sZDmDKy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"materials = {\n    \"Seawater\"          : (0.2,   1),\n    \"Clay\"              : (1,    20),\n    \"Groundwater\"       : (10,  100),\n    \"Moist soil\"        : (20,  200),\n    \"Dry sand / gravel\" : (200, 2000),\n    \"Limestone\"         : (500, 10000),\n    \"Granite\"           : (1e4, 1e6),\n}\n\nfig, ax = plt.subplots(figsize=(9, 4))\nfor i, (mat, (lo, hi)) in enumerate(materials.items()):\n    ax.barh(i, np.log10(hi) - np.log10(lo),\n            left=np.log10(lo), height=0.6,\n            color=plt.cm.RdYlBu_r(i / len(materials)), edgecolor='k', linewidth=0.5)\n    ax.text(np.log10(lo) - 0.05, i, mat, ha='right', va='center', fontsize=9)\n\nax.set_xlabel(\"log₁₀(Resistivity / Ω·m)\")\nax.set_title(\"Typical resistivity ranges for earth materials\")\nax.set_yticks([])\nax.set_xlim(-1, 7)\nax.grid(axis='x', alpha=0.3)\nplt.tight_layout()\nplt.show()","visibility":"hide","key":"AAV7BS436N"},{"type":"output","id":"CGO3erP1EwRI0y29rLcW7","data":[],"visibility":"show","key":"QyYHWMPZQC"}],"data":{"tags":[]},"visibility":"show","key":"OHELw9fpXJ"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"🎛️ Interactive Explorer — Material Resistivity","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"ZQkIjVt2Z4"}],"identifier":"id-interactive-explorer-material-resistivity","label":"🎛️ Interactive Explorer — Material Resistivity","html_id":"id-interactive-explorer-material-resistivity","implicit":true,"key":"K7clLrRQ67"},{"type":"paragraph","position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"children":[{"type":"text","value":"Hover over a material to highlight its range, or select one to see its typical properties:","position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"key":"PyciM65OJZ"}],"key":"mB5Kit0lSz"}],"key":"tzUpBwsd41"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def material_widget():\n    mat_names = list(materials.keys())\n    dropdown = widgets.Dropdown(\n        options=mat_names,\n        value='Moist soil',\n        description='Material:',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='350px')\n    )\n    out = widgets.Output()\n\n    def update(change=None):\n        mat = dropdown.value\n        lo, hi = materials[mat]\n        sigma_lo = 1 / hi\n        sigma_hi = 1 / lo\n        with out:\n            out.clear_output(wait=True)\n            fig, ax = plt.subplots(figsize=(8, 1.8))\n            for i, (m, (l, h)) in enumerate(materials.items()):\n                color = 'steelblue' if m == mat else 'lightgrey'\n                ax.barh(0, np.log10(h) - np.log10(l),\n                        left=np.log10(l), height=0.5,\n                        color=color, edgecolor='k', linewidth=0.4, alpha=0.9)\