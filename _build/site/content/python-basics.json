asurements}\")","key":"ht3dnmYy6m"},{"type":"outputs","id":"jPZzzsm0HvQTXmim7a_Jg","children":[],"key":"NPHKHWcqob"}],"key":"ylTDP4pFi3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the type of a variable\nprint(type(resistivity))\nprint(type(num_electrodes))\nprint(type(survey_type))\nprint(type(measurements))","key":"KOI4ZT7MpP"},{"type":"outputs","id":"uOUmonNjWHQx1AMkFSEWN","children":[],"key":"rlUu0UIBQp"}],"key":"xdXyO07TE0"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"Cf3zHZNAFb"},{"type":"heading","depth":2,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"Control Structures","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"emyc8r4Tne"}],"identifier":"control-structures","label":"Control Structures","html_id":"control-structures","implicit":true,"key":"eiaHXxdxlH"},{"type":"heading","depth":3,"position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"Conditionals","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"SJ2BicwxqZ"}],"identifier":"conditionals","label":"Conditionals","html_id":"conditionals","implicit":true,"key":"qcrE5LZM34"}],"key":"V1DXrFj5nc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rho = 250  # Ohm·m\n\nif rho < 10:\n    print(\"Very conductive — possible clay or saline water\")\nelif rho < 100:\n    print(\"Moderately conductive — moist soil\")\nelif rho < 1000:\n    print(\"Resistive — dry soil or gravel\")\nelse:\n    print(\"Highly resistive — bedrock or dry sand\")","key":"r1PmK213hP"},{"type":"outputs","id":"IrdQo1i7xlbQws_QImnZW","children":[],"key":"R6TacNNxGp"}],"key":"HPmbb5tsCA"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"Loops","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"gGPxWrR5Wv"}],"identifier":"loops","label":"Loops","html_id":"loops","implicit":true,"key":"F7T1JIfXRh"}],"key":"okIe6mamOb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"electrode_positions = [0, 1, 2, 3, 4]  # metres\n\nfor i, pos in enumerate(electrode_positions):\n    print(f\"Electrode {i+1:2d}  →  x = {pos} m\")","key":"xpOWqTnMl4"},{"type":"outputs","id":"13He0ldt2-szGZeElHaEi","children":[],"key":"T78FgSfO6V"}],"key":"iG93UHVoZz"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"XHJmJJw66Q"},{"type":"heading","depth":2,"position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"children":[{"type":"text","value":"Functions","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"UBThCYRigh"}],"identifier":"functions","label":"Functions","html_id":"functions","implicit":true,"key":"kuD8ZY01mi"},{"type":"paragraph","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"children":[{"type":"text","value":"Functions let you package reusable logic with a clear interface.","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"key":"ic6TAdfe7V"}],"key":"y9pZVIiRzz"}],"key":"ysNg5e8aR1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def apparent_resistivity(V, I, K):\n    \"\"\"\n    Calculate apparent resistivity.\n\n    Parameters\n    ----------\n    V : float\n        Measured voltage (V)\n    I : float\n        Applied current (A)\n    K : float\n        Geometric factor for the array (m)\n\n    Returns\n    -------\n    float\n        Apparent resistivity (Ω·m)\n    \"\"\"\n    return K * (V / I)\n\n# Wenner array with a = 1 m → K = 2πa\nimport math\na = 1.0          # electrode spacing (m)\nK_wenner = 2 * math.pi * a\n\nrho_a = apparent_resistivity(V=0.05, I=0.001, K=K_wenner)\nprint(f\"Apparent resistivity: {rho_a:.1f} Ω·m\")","key":"lsTlmXbEdx"},{"type":"outputs","id":"wgSZT0za7LLCp3gAunjOY","children":[],"key":"YvwZflzVKB"}],"key":"MfgisUI9wF"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"key":"PZSWiTGNT3"},{"type":"heading","depth":2,"position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"children":[{"type":"text","value":"NumPy Basics","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"key":"hbqbXm6jCq"}],"identifier":"numpy-basics","label":"NumPy Basics","html_id":"numpy-basics","implicit":true,"key":"b6oVGRM558"},{"type":"paragraph","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"link","url":"https://numpy.org","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"text","value":"NumPy","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"T981JlUrdM"}],"urlSource":"https://numpy.org","key":"ivZWKQhlbk"},{"type":"text","value":" is the backbone of numerical computing in Python.","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"POM7AtkdsZ"}],"key":"jL6wqdd6WF"}],"key":"Q0dJaJsO0N"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Create an array of electrode positions\nx = np.linspace(0, 47, 48)   # 48 electrodes, 1 m spacing\nprint(f\"Electrode positions: {x[:6]} ... {x[-3:]}\")\nprint(f\"Array shape: {x.shape}\")\n\n# Vectorised arithmetic — no loops needed\nrho_values = np.random.lognormal(mean=4.5, sigma=0.5, size=48)\nprint(f\"\\nMean apparent resistivity : {rho_values.mean():.1f} Ω·m\")\nprint(f\"Std  apparent resistivity : {rho_values.std():.1f} Ω·m\")","key":"BFLji5HhFC"},{"type":"outputs","id":"gEafMkqMUbKDkTDHbNCTC","children":[],"key":"GI99Ng9CZ9"}],"key":"fhVdzQHH8O"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"y184hSMQ62"},{"type":"heading","depth":2,"position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"Matplotlib Quick Plot","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"CV6bJhzGPf"}],"identifier":"matplotlib-quick-plot","label":"Matplotlib Quick Plot","html_id":"matplotlib-quick-plot","implicit":true,"key":"DcYmd3EvmP"}],"key":"R470jCz1xs"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(figsize=(9, 3))\nax.plot(x, rho_values, 'o-', color='steelblue', markersize=4, linewidth=1)\nax.set_xlabel(\"Electrode position (m)\")\nax.set_ylabel(\"Apparent resistivity (Ω·m)\")\nax.set_title(\"Synthetic resistivity profile — Wenner array\")\nax.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"GbDcgl2JBU"},{"type":"outputs","id":"0kAxpWNbuuJTE-gKTgaB4","children":[],"key":"fXNaWAKpMw"}],"key":"mThHb6dRFe"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":163,"column":1},"end":{"line":163,"column":1}},"key":"DNHwF4ovzh"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Summary","position":{"start":{"line":165,"column":1},"end":{"line":165,"column":1}},"key":"eyCzpVkSMP"}],"key":"TpVACSEKUi"},{"type":"paragraph","position":{"start":{"line":167,"column":1},"end":{"line":167,"column":1}},"children":[{"type":"text","value":"You have covered:","position":{"start":{"line":167,"column":1},"end":{"line":167,"column":1}},"key":"cRIR4U8Fgg"}],"key":"s6PhTEhO78"},{"type":"list","