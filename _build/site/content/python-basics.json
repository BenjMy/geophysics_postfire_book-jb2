ey_type}\")\nprint(f\"Electrodes        : {num_electrodes}\")\nprint(f\"Resistivity (Ω·m) : {resistivity}\")\nprint(f\"Measurements      : {measurements}\")","key":"u7IUKTfqsQ"},{"type":"outputs","id":"KYDfzCuomhw1PdWaRYSKd","children":[],"key":"xcRTPKQpJv"}],"key":"w7DqAf7Vvt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the type of a variable\nprint(type(resistivity))\nprint(type(num_electrodes))\nprint(type(survey_type))\nprint(type(measurements))","key":"Hpn8YNvL1l"},{"type":"outputs","id":"wrMGwcEkwgCH4mg9yP7UB","children":[],"key":"Qn6YnqKtJS"}],"key":"b3V8tO1h0Y"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"kQtEJ4BXUV"},{"type":"heading","depth":2,"position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"Control Structures","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"lBu6Tg43es"}],"identifier":"control-structures","label":"Control Structures","html_id":"control-structures","implicit":true,"key":"WWDaPFzFvo"},{"type":"heading","depth":3,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"Conditionals","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"i5SiXkgBbO"}],"identifier":"conditionals","label":"Conditionals","html_id":"conditionals","implicit":true,"key":"C8xTXWw55C"}],"key":"izm2JHzD51"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rho = 250  # Ohm·m\n\nif rho < 10:\n    print(\"Very conductive — possible clay or saline water\")\nelif rho < 100:\n    print(\"Moderately conductive — moist soil\")\nelif rho < 1000:\n    print(\"Resistive — dry soil or gravel\")\nelse:\n    print(\"Highly resistive — bedrock or dry sand\")","key":"c3VmPEKolV"},{"type":"outputs","id":"46xnfVGqFEzQvxaJ2FCqW","children":[],"key":"s2CrTz5P7V"}],"key":"zC2NaGyfjw"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Loops","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"Qi6nXGiHpz"}],"identifier":"loops","label":"Loops","html_id":"loops","implicit":true,"key":"yAZYbJ64lb"}],"key":"zkRR0mxQa1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"electrode_positions = [0, 1, 2, 3, 4]  # metres\n\nfor i, pos in enumerate(electrode_positions):\n    print(f\"Electrode {i+1:2d}  →  x = {pos} m\")","key":"DVdjFys4m4"},{"type":"outputs","id":"xvp-qqfWmXBUibbRUVwuy","children":[],"key":"ZgcFUEGQ1l"}],"key":"qE7PCJbVyi"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"key":"J9xzHd4L4Y"},{"type":"heading","depth":2,"position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"Functions","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"RuzOgdJwjP"}],"identifier":"functions","label":"Functions","html_id":"functions","implicit":true,"key":"SgmckhV5Ja"},{"type":"paragraph","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"Functions let you package reusable logic with a clear interface.","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"YxDIzmqwoC"}],"key":"lGaMsKgKiZ"}],"key":"IATw2DJRpO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def apparent_resistivity(V, I, K):\n    \"\"\"\n    Calculate apparent resistivity.\n\n    Parameters\n    ----------\n    V : float\n        Measured voltage (V)\n    I : float\n        Applied current (A)\n    K : float\n        Geometric factor for the array (m)\n\n    Returns\n    -------\n    float\n        Apparent resistivity (Ω·m)\n    \"\"\"\n    return K * (V / I)\n\n# Wenner array with a = 1 m → K = 2πa\nimport math\na = 1.0          # electrode spacing (m)\nK_wenner = 2 * math.pi * a\n\nrho_a = apparent_resistivity(V=0.05, I=0.001, K=K_wenner)\nprint(f\"Apparent resistivity: {rho_a:.1f} Ω·m\")","key":"nQjQlTS40Z"},{"type":"outputs","id":"mPBp_ukzpybzJ-T7Uaftf","children":[],"key":"SsJ325S67M"}],"key":"fxMWLMvbCM"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"key":"MTvH0Fws8E"},{"type":"heading","depth":2,"position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"children":[{"type":"text","value":"NumPy Basics","position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"key":"yof4cmh4x7"}],"identifier":"numpy-basics","label":"NumPy Basics","html_id":"numpy-basics","implicit":true,"key":"lodRiEHtnW"},{"type":"paragraph","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"link","url":"https://numpy.org","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"text","value":"NumPy","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"rkEj2D8U5I"}],"urlSource":"https://numpy.org","key":"xxWoddoLB3"},{"type":"text","value":" is the backbone of numerical computing in Python.","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"GqUBfU3bw5"}],"key":"gBArjNwYhE"}],"key":"Vfopt36bGi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Create an array of electrode positions\nx = np.linspace(0, 47, 48)   # 48 electrodes, 1 m spacing\nprint(f\"Electrode positions: {x[:6]} ... {x[-3:]}\")\nprint(f\"Array shape: {x.shape}\")\n\n# Vectorised arithmetic — no loops needed\nrho_values = np.random.lognormal(mean=4.5, sigma=0.5, size=48)\nprint(f\"\\nMean apparent resistivity : {rho_values.mean():.1f} Ω·m\")\nprint(f\"Std  apparent resistivity : {rho_values.std():.1f} Ω·m\")","key":"ZMsUHBKhTO"},{"type":"outputs","id":"O-GUPugAdsGe6VXXWvEzC","children":[],"key":"k10VfHQQ0M"}],"key":"dBWJXp4MsN"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":156,"column":1},"end":{"line":156,"column":1}},"key":"VJlEVkM8AD"},{"type":"heading","depth":2,"position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"children":[{"type":"text","value":"Matplotlib Quick Plot","position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"key":"BEfnNYUifM"}],"identifier":"matplotlib-quick-plot","label":"Matplotlib Quick Plot","html_id":"matplotlib-quick-plot","implicit":true,"key":"fvcv760naW"}],"key":"S7EXkP9BWX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(figsize=(9, 3))\nax.plot(x, rho_values, 'o-', color='steelblue', markersize=4, linewidth=1)\nax.set_xlabel(\"Electrode position (m)\")\nax.set_ylabel(\"Apparent resistivity (Ω·m)\")\nax.set_title(\"Synthetic resistivity profile — Wenner array\")\nax.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"SnZiIlt5K1"},{"type":"outputs","id":"4_CouSCpetWdRuI8JLjLH","children":[],"key":"s1r4NPeWVl"}],"key":"U2ECwK0Dx6"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"IFai6ofaPN"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Summary","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"ojhVh39Y36"}],"key":"gYxu3tTJu8"},{"type":"paragraph","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"children":[{"type":"text","value":