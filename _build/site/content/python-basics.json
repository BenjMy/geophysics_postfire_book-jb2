ey_type}\")\nprint(f\"Electrodes        : {num_electrodes}\")\nprint(f\"Resistivity (Ω·m) : {resistivity}\")\nprint(f\"Measurements      : {measurements}\")","key":"rnxtJMBnDq"},{"type":"outputs","id":"KTzEHlf1LD6AyYu7XCzYs","children":[],"key":"q6GxEYGo9d"}],"key":"yP42gPPWIj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the type of a variable\nprint(type(resistivity))\nprint(type(num_electrodes))\nprint(type(survey_type))\nprint(type(measurements))","key":"TRyrRpxPDO"},{"type":"outputs","id":"SQy-e_J91VGSmNCqbqPC4","children":[],"key":"QvgCB1WIgS"}],"key":"R9JjMYdZfn"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"PKi5er17Yn"},{"type":"heading","depth":2,"position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"Control Structures","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"FtIKyQ6mDw"}],"identifier":"control-structures","label":"Control Structures","html_id":"control-structures","implicit":true,"key":"FBatxzPH0j"},{"type":"heading","depth":3,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"Conditionals","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"dT1zGFf36w"}],"identifier":"conditionals","label":"Conditionals","html_id":"conditionals","implicit":true,"key":"WiN38b0yL8"}],"key":"ea5mxJHpMd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rho = 250  # Ohm·m\n\nif rho < 10:\n    print(\"Very conductive — possible clay or saline water\")\nelif rho < 100:\n    print(\"Moderately conductive — moist soil\")\nelif rho < 1000:\n    print(\"Resistive — dry soil or gravel\")\nelse:\n    print(\"Highly resistive — bedrock or dry sand\")","key":"svVG52s72N"},{"type":"outputs","id":"SNQJwTORTMAMOVhhbj8Pr","children":[],"key":"sYVYmiVYXn"}],"key":"GyI30PGrjJ"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Loops","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"VlE3vp2ZLP"}],"identifier":"loops","label":"Loops","html_id":"loops","implicit":true,"key":"bR5f7lKYbW"}],"key":"CuZ2ufxQ7s"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"electrode_positions = [0, 1, 2, 3, 4]  # metres\n\nfor i, pos in enumerate(electrode_positions):\n    print(f\"Electrode {i+1:2d}  →  x = {pos} m\")","key":"i2kUYdJ9i7"},{"type":"outputs","id":"p9dbNs8DTNpgrHk5Juf2F","children":[],"key":"cOkCbxFH1z"}],"key":"zIRlA2bchN"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"key":"SeEgJsQknG"},{"type":"heading","depth":2,"position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"Functions","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"cKcOa6plY0"}],"identifier":"functions","label":"Functions","html_id":"functions","implicit":true,"key":"wXqaYByAiv"},{"type":"paragraph","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"Functions let you package reusable logic with a clear interface.","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"WmcKuYBOVv"}],"key":"BQxu8uZhG0"}],"key":"EB5fokoLMf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def apparent_resistivity(V, I, K):\n    \"\"\"\n    Calculate apparent resistivity.\n\n    Parameters\n    ----------\n    V : float\n        Measured voltage (V)\n    I : float\n        Applied current (A)\n    K : float\n        Geometric factor for the array (m)\n\n    Returns\n    -------\n    float\n        Apparent resistivity (Ω·m)\n    \"\"\"\n    return K * (V / I)\n\n# Wenner array with a = 1 m → K = 2πa\nimport math\na = 1.0          # electrode spacing (m)\nK_wenner = 2 * math.pi * a\n\nrho_a = apparent_resistivity(V=0.05, I=0.001, K=K_wenner)\nprint(f\"Apparent resistivity: {rho_a:.1f} Ω·m\")","key":"Y5lVj3m7eo"},{"type":"outputs","id":"HojpI1T5RRZ7kHoKm74iX","children":[],"key":"QHGd54wGHK"}],"key":"YdoNBklVq8"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"key":"iPAAvOLwSC"},{"type":"heading","depth":2,"position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"children":[{"type":"text","value":"NumPy Basics","position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"key":"lwI6bago7l"}],"identifier":"numpy-basics","label":"NumPy Basics","html_id":"numpy-basics","implicit":true,"key":"dQcs8JDQXn"},{"type":"paragraph","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"link","url":"https://numpy.org","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"text","value":"NumPy","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"jmTUWbnWFj"}],"urlSource":"https://numpy.org","key":"uuOh3dI56u"},{"type":"text","value":" is the backbone of numerical computing in Python.","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"fjXyqKnofK"}],"key":"LOafIsq6y1"}],"key":"wRW2nkOIBL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Create an array of electrode positions\nx = np.linspace(0, 47, 48)   # 48 electrodes, 1 m spacing\nprint(f\"Electrode positions: {x[:6]} ... {x[-3:]}\")\nprint(f\"Array shape: {x.shape}\")\n\n# Vectorised arithmetic — no loops needed\nrho_values = np.random.lognormal(mean=4.5, sigma=0.5, size=48)\nprint(f\"\\nMean apparent resistivity : {rho_values.mean():.1f} Ω·m\")\nprint(f\"Std  apparent resistivity : {rho_values.std():.1f} Ω·m\")","key":"uIpdaGhZzF"},{"type":"outputs","id":"g-0UhVzkGut51eNFNz9wx","children":[],"key":"lxJC9d0Wx6"}],"key":"iCfgbnZeVT"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":156,"column":1},"end":{"line":156,"column":1}},"key":"clvB7cyOGc"},{"type":"heading","depth":2,"position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"children":[{"type":"text","value":"Matplotlib Quick Plot","position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"key":"Wo58gOx7u5"}],"identifier":"matplotlib-quick-plot","label":"Matplotlib Quick Plot","html_id":"matplotlib-quick-plot","implicit":true,"key":"oAS6RGSPcI"}],"key":"cFfPYbwJrW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(figsize=(9, 3))\nax.plot(x, rho_values, 'o-', color='steelblue', markersize=4, linewidth=1)\nax.set_xlabel(\"Electrode position (m)\")\nax.set_ylabel(\"Apparent resistivity (Ω·m)\")\nax.set_title(\"Synthetic resistivity profile — Wenner array\")\nax.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"cKw08hXZA6"},{"type":"outputs","id":"dHS7uShjy_gFiyoQD9DtK","children":[],"key":"cm7xGKe1zc"}],"key":"JdTCrcswuX"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"PqbD31k0SI"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Summary","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"In5dFYyRYu"}],"key":"jPmCb1EryK"},{"type":"paragraph","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"children":[{"type":"text","value":