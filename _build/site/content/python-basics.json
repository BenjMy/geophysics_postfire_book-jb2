List  \nmeasurements = [12.5, 15.3, 18.7, 21.2]  # apparent resistivity values\n\nprint(f\"Survey type       : {survey_type}\")\nprint(f\"Electrodes        : {num_electrodes}\")\nprint(f\"Resistivity (Ω·m) : {resistivity}\")\nprint(f\"Measurements      : {measurements}\")","key":"LquXibZ5fI"},{"type":"outputs","id":"TIMVhYR_B5CAp3xolIV2l","children":[],"key":"Ujg0bHUABq"}],"key":"olcatwrG7M"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the type of a variable\nprint(type(resistivity))\nprint(type(num_electrodes))\nprint(type(survey_type))\nprint(type(measurements))","key":"UQrnzfIyv6"},{"type":"outputs","id":"gDG6ZLiEW6TVWrkk4fpp3","children":[],"key":"vzRDMbQp8b"}],"key":"XB4pEQvWKF"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"iuneCeBS2K"},{"type":"heading","depth":2,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"Control Structures","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"NOwZ2VlVQs"}],"identifier":"control-structures","label":"Control Structures","html_id":"control-structures","implicit":true,"key":"NmPiMsEr8u"},{"type":"heading","depth":3,"position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"Conditionals","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"hr59oLiuxd"}],"identifier":"conditionals","label":"Conditionals","html_id":"conditionals","implicit":true,"key":"IMZ6hn5B7Z"}],"key":"cLz1LipH4C"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rho = 250  # Ohm·m\n\nif rho < 10:\n    print(\"Very conductive — possible clay or saline water\")\nelif rho < 100:\n    print(\"Moderately conductive — moist soil\")\nelif rho < 1000:\n    print(\"Resistive — dry soil or gravel\")\nelse:\n    print(\"Highly resistive — bedrock or dry sand\")","key":"u5cdkDQIzk"},{"type":"outputs","id":"Vf5Zmr2kJ3E0-zAI4upF7","children":[],"key":"fE0SOej5PT"}],"key":"nZV48GGSDn"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"Loops","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"CZwaxyrQdZ"}],"identifier":"loops","label":"Loops","html_id":"loops","implicit":true,"key":"rRBqDf9MID"}],"key":"kixxutojg9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"electrode_positions = [0, 1, 2, 3, 4]  # metres\n\nfor i, pos in enumerate(electrode_positions):\n    print(f\"Electrode {i+1:2d}  →  x = {pos} m\")","key":"iokVUWQMXL"},{"type":"outputs","id":"gwWmd0uWtWlY1mpeeIpy1","children":[],"key":"yMwiY7yzVN"}],"key":"B20BoZAgLJ"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"AitLetefeo"},{"type":"heading","depth":2,"position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"children":[{"type":"text","value":"Functions","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"cBYnnDdZiX"}],"identifier":"functions","label":"Functions","html_id":"functions","implicit":true,"key":"qqyCK2AF11"},{"type":"paragraph","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"children":[{"type":"text","value":"Functions let you package reusable logic with a clear interface.","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"key":"BLkd6YvQZZ"}],"key":"YrvVLXzHez"}],"key":"KHto906t3P"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def apparent_resistivity(V, I, K):\n    \"\"\"\n    Calculate apparent resistivity.\n\n    Parameters\n    ----------\n    V : float\n        Measured voltage (V)\n    I : float\n        Applied current (A)\n    K : float\n        Geometric factor for the array (m)\n\n    Returns\n    -------\n    float\n        Apparent resistivity (Ω·m)\n    \"\"\"\n    return K * (V / I)\n\n# Wenner array with a = 1 m → K = 2πa\nimport math\na = 1.0          # electrode spacing (m)\nK_wenner = 2 * math.pi * a\n\nrho_a = apparent_resistivity(V=0.05, I=0.001, K=K_wenner)\nprint(f\"Apparent resistivity: {rho_a:.1f} Ω·m\")","key":"tZBLjjF0nG"},{"type":"outputs","id":"0m5-fdW51zOdZQ6U66L4d","children":[],"key":"Oxljf43bgZ"}],"key":"ACECqD7W3t"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"key":"hcMyx8QAhj"},{"type":"heading","depth":2,"position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"children":[{"type":"text","value":"NumPy Basics","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"key":"iJTKRWueU0"}],"identifier":"numpy-basics","label":"NumPy Basics","html_id":"numpy-basics","implicit":true,"key":"vkizc79i6b"},{"type":"paragraph","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"link","url":"https://numpy.org","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"text","value":"NumPy","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"XABLieeT2r"}],"urlSource":"https://numpy.org","key":"lMhjrYP3oQ"},{"type":"text","value":" is the backbone of numerical computing in Python.","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"oiIxyBfqNE"}],"key":"YUbg7VHQSC"}],"key":"x8I8TYs8MD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Create an array of electrode positions\nx = np.linspace(0, 47, 48)   # 48 electrodes, 1 m spacing\nprint(f\"Electrode positions: {x[:6]} ... {x[-3:]}\")\nprint(f\"Array shape: {x.shape}\")\n\n# Vectorised arithmetic — no loops needed\nrho_values = np.random.lognormal(mean=4.5, sigma=0.5, size=48)\nprint(f\"\\nMean apparent resistivity : {rho_values.mean():.1f} Ω·m\")\nprint(f\"Std  apparent resistivity : {rho_values.std():.1f} Ω·m\")","key":"harIIojFqr"},{"type":"outputs","id":"R_cknRS6YfoQ_IKOnC-3h","children":[],"key":"zUtJL51nOh"}],"key":"H2gFveg3zU"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"vgihXox5n3"},{"type":"heading","depth":2,"position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"Matplotlib Quick Plot","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"AB4qbni0Mz"}],"identifier":"matplotlib-quick-plot","label":"Matplotlib Quick Plot","html_id":"matplotlib-quick-plot","implicit":true,"key":"WZFjwoc3nq"}],"key":"MRJMBL89Gy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(figsize=(9, 3))\nax.plot(x, rho_values, 'o-', color='steelblue', markersize=4, linewidth=1)\nax.set_xlabel(\"Electrode position (m)\")\nax.set_ylabel(\"Apparent resistivity (Ω·m)\")\nax.set_title(\"Synthetic resistivity profile — Wenner array\")\nax.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"EHmximj3Rf"},{"type":"outputs","id":"mcfxoFkDAJb-79RJ7erpR","children":[],"key":"Ajhr9jnvT2"}],"key":"JYEmkGTiTR"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":163,"column":1},"end":{"line":163,"column":1}},"key":"p3XO3wmGCF"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Summary","position":{"start":{"line":165,"column":1},"end":{"line":165,"column":1}},"key":"VTIkUcFhxh"}],"key":"BmESIyLioE"},{"type":"paragraph","pos