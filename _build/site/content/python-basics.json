List  \nmeasurements = [12.5, 15.3, 18.7, 21.2]  # apparent resistivity values\n\nprint(f\"Survey type       : {survey_type}\")\nprint(f\"Electrodes        : {num_electrodes}\")\nprint(f\"Resistivity (Ω·m) : {resistivity}\")\nprint(f\"Measurements      : {measurements}\")","key":"tYrt1Om6RW"},{"type":"outputs","id":"TIMVhYR_B5CAp3xolIV2l","children":[],"key":"xS8aqPojHM"}],"key":"NnWf2NYs26"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the type of a variable\nprint(type(resistivity))\nprint(type(num_electrodes))\nprint(type(survey_type))\nprint(type(measurements))","key":"d6CtQdFgle"},{"type":"outputs","id":"gDG6ZLiEW6TVWrkk4fpp3","children":[],"key":"ZsOCcPRxGe"}],"key":"BTOxkc7KFH"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"azb9nOq3wM"},{"type":"heading","depth":2,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"Control Structures","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"ARY6FGCeej"}],"identifier":"control-structures","label":"Control Structures","html_id":"control-structures","implicit":true,"key":"JHrhkwIEOB"},{"type":"heading","depth":3,"position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"Conditionals","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"qzdiCIAHM3"}],"identifier":"conditionals","label":"Conditionals","html_id":"conditionals","implicit":true,"key":"Yfdp2xzo34"}],"key":"tSCrJGUh6D"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rho = 250  # Ohm·m\n\nif rho < 10:\n    print(\"Very conductive — possible clay or saline water\")\nelif rho < 100:\n    print(\"Moderately conductive — moist soil\")\nelif rho < 1000:\n    print(\"Resistive — dry soil or gravel\")\nelse:\n    print(\"Highly resistive — bedrock or dry sand\")","key":"tL4VA3GLfH"},{"type":"outputs","id":"Vf5Zmr2kJ3E0-zAI4upF7","children":[],"key":"s39uv855S0"}],"key":"XpXOfA4Nlo"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"Loops","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"EsbpzSR21O"}],"identifier":"loops","label":"Loops","html_id":"loops","implicit":true,"key":"CDcfaGU18r"}],"key":"gYRqLNb9yZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"electrode_positions = [0, 1, 2, 3, 4]  # metres\n\nfor i, pos in enumerate(electrode_positions):\n    print(f\"Electrode {i+1:2d}  →  x = {pos} m\")","key":"kh2w0twQYS"},{"type":"outputs","id":"gwWmd0uWtWlY1mpeeIpy1","children":[],"key":"N1YECLEKMx"}],"key":"mpTEErL1y0"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"lcg5FrCmRd"},{"type":"heading","depth":2,"position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"children":[{"type":"text","value":"Functions","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"v7p8ycIfQc"}],"identifier":"functions","label":"Functions","html_id":"functions","implicit":true,"key":"AAQ9QPHBSC"},{"type":"paragraph","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"children":[{"type":"text","value":"Functions let you package reusable logic with a clear interface.","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"key":"S00RtRft1J"}],"key":"VWaiKpPG3L"}],"key":"gyBKYAaIJJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def apparent_resistivity(V, I, K):\n    \"\"\"\n    Calculate apparent resistivity.\n\n    Parameters\n    ----------\n    V : float\n        Measured voltage (V)\n    I : float\n        Applied current (A)\n    K : float\n        Geometric factor for the array (m)\n\n    Returns\n    -------\n    float\n        Apparent resistivity (Ω·m)\n    \"\"\"\n    return K * (V / I)\n\n# Wenner array with a = 1 m → K = 2πa\nimport math\na = 1.0          # electrode spacing (m)\nK_wenner = 2 * math.pi * a\n\nrho_a = apparent_resistivity(V=0.05, I=0.001, K=K_wenner)\nprint(f\"Apparent resistivity: {rho_a:.1f} Ω·m\")","key":"y5U5mUaKSP"},{"type":"outputs","id":"0m5-fdW51zOdZQ6U66L4d","children":[],"key":"ohxT1RiD8i"}],"key":"oANyDVYbg6"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"key":"gj6zIjCge9"},{"type":"heading","depth":2,"position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"children":[{"type":"text","value":"NumPy Basics","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"key":"kWSkxBaWms"}],"identifier":"numpy-basics","label":"NumPy Basics","html_id":"numpy-basics","implicit":true,"key":"ry6MKCkyva"},{"type":"paragraph","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"link","url":"https://numpy.org","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"children":[{"type":"text","value":"NumPy","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"wrqa7wYvmU"}],"urlSource":"https://numpy.org","key":"fIxvKKEEb0"},{"type":"text","value":" is the backbone of numerical computing in Python.","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"tOKwR95Jr8"}],"key":"AqEGbavxLt"}],"key":"ZYa6QplyOF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Create an array of electrode positions\nx = np.linspace(0, 47, 48)   # 48 electrodes, 1 m spacing\nprint(f\"Electrode positions: {x[:6]} ... {x[-3:]}\")\nprint(f\"Array shape: {x.shape}\")\n\n# Vectorised arithmetic — no loops needed\nrho_values = np.random.lognormal(mean=4.5, sigma=0.5, size=48)\nprint(f\"\\nMean apparent resistivity : {rho_values.mean():.1f} Ω·m\")\nprint(f\"Std  apparent resistivity : {rho_values.std():.1f} Ω·m\")","key":"mJglOZLJXv"},{"type":"outputs","id":"R_cknRS6YfoQ_IKOnC-3h","children":[],"key":"U4HrixFSDJ"}],"key":"YxqQEeoLlp"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"Oie7P7QXGO"},{"type":"heading","depth":2,"position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"Matplotlib Quick Plot","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"qfcwAavRra"}],"identifier":"matplotlib-quick-plot","label":"Matplotlib Quick Plot","html_id":"matplotlib-quick-plot","implicit":true,"key":"G5St0vc8Vo"}],"key":"CchlzQLP2E"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(figsize=(9, 3))\nax.plot(x, rho_values, 'o-', color='steelblue', markersize=4, linewidth=1)\nax.set_xlabel(\"Electrode position (m)\")\nax.set_ylabel(\"Apparent resistivity (Ω·m)\")\nax.set_title(\"Synthetic resistivity profile — Wenner array\")\nax.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"b0HqU6dtDz"},{"type":"outputs","id":"mcfxoFkDAJb-79RJ7erpR","children":[],"key":"sFCVtYB4iP"}],"key":"CG2DNCqitx"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":163,"column":1},"end":{"line":163,"column":1}},"key":"UUZv13f3Xg"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Summary","position":{"start":{"line":165,"column":1},"end":{"line":165,"column":1}},"key":"MWMCrazQLM"}],"key":"M80J8pChYR"},{"type":"paragraph","pos