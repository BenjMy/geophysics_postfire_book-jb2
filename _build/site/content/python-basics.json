parent resistivity values\n\nprint(f\"Survey type       : {survey_type}\")\nprint(f\"Electrodes        : {num_electrodes}\")\nprint(f\"Resistivity (Ω·m) : {resistivity}\")\nprint(f\"Measurements      : {measurements}\")","key":"xeNllzNSYO"},{"type":"outputs","id":"jDGge3PBq9SEzFPzuQFXf","children":[],"key":"kkOBomzb6a"}],"key":"D8eKVcT3E5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the type of a variable\nprint(type(resistivity))\nprint(type(num_electrodes))\nprint(type(survey_type))\nprint(type(measurements))","key":"wOxZxcDLtt"},{"type":"outputs","id":"fHuWdFaneSCPTj0eXzLzZ","children":[],"key":"atsG7yfPFw"}],"key":"n1dVuXQNKH"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"YbezZJVHJQ"},{"type":"heading","depth":2,"position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"Control Structures","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"YkJpNxuqoh"}],"identifier":"control-structures","label":"Control Structures","html_id":"control-structures","implicit":true,"key":"dGys0pEQcU"},{"type":"heading","depth":3,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"Conditionals","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"bnX8fThoId"}],"identifier":"conditionals","label":"Conditionals","html_id":"conditionals","implicit":true,"key":"cPBdwmrDPD"}],"key":"A4WTNZYe9b"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rho = 250  # Ohm·m\n\nif rho < 10:\n    print(\"Very conductive — possible clay or saline water\")\nelif rho < 100:\n    print(\"Moderately conductive — moist soil\")\nelif rho < 1000:\n    print(\"Resistive — dry soil or gravel\")\nelse:\n    print(\"Highly resistive — bedrock or dry sand\")","key":"bL0TscvVBm"},{"type":"outputs","id":"KwtvV3idqCMUUuZpGss1S","children":[],"key":"pXUE4o4QE0"}],"key":"PGm2cnjljr"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Loops","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"kXqSSyHRC2"}],"identifier":"loops","label":"Loops","html_id":"loops","implicit":true,"key":"nfONmEjAKb"}],"key":"Q2Qv7cDyHl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"electrode_positions = [0, 1, 2, 3, 4]  # metres\n\nfor i, pos in enumerate(electrode_positions):\n    print(f\"Electrode {i+1:2d}  →  x = {pos} m\")","key":"WsZvLiCEGR"},{"type":"outputs","id":"GR8hjAG59A4OeoXDGvNiL","children":[],"key":"r8NFsMRy5l"}],"key":"Y7yRLtqksb"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"key":"wk4mIlqp4u"},{"type":"heading","depth":2,"position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"Functions","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"OLFGtK13rw"}],"identifier":"functions","label":"Functions","html_id":"functions","implicit":true,"key":"zsjguHgivv"},{"type":"paragraph","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"Functions let you package reusable logic with a clear interface.","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"u56lSL31rQ"}],"key":"Tt0UjmXR8K"}],"key":"wt69h2KySW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def apparent_resistivity(V, I, K):\n    \"\"\"\n    Calculate apparent resistivity.\n\n    Parameters\n    ----------\n    V : float\n        Measured voltage (V)\n    I : float\n        Applied current (A)\n    K : float\n        Geometric factor for the array (m)\n\n    Returns\n    -------\n    float\n        Apparent resistivity (Ω·m)\n    \"\"\"\n    return K * (V / I)\n\n# Wenner array with a = 1 m → K = 2πa\nimport math\na = 1.0          # electrode spacing (m)\nK_wenner = 2 * math.pi * a\n\nrho_a = apparent_resistivity(V=0.05, I=0.001, K=K_wenner)\nprint(f\"Apparent resistivity: {rho_a:.1f} Ω·m\")","key":"hcBQLSruGV"},{"type":"outputs","id":"oqZHbsp1llMc4DNIaEajs","children":[],"key":"F9CvJwvToL"}],"key":"n7TJgV0e0K"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"key":"n5vdM2JBxR"},{"type":"heading","depth":2,"position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"children":[{"type":"text","value":"NumPy Basics","position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"key":"L0d4HqALWC"}],"identifier":"numpy-basics","label":"NumPy Basics","html_id":"numpy-basics","implicit":true,"key":"WFmFNvyPQK"},{"type":"paragraph","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"link","url":"https://numpy.org","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"text","value":"NumPy","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"QhhCQsjkpO"}],"urlSource":"https://numpy.org","key":"KttaUKVwtk"},{"type":"text","value":" is the backbone of numerical computing in Python.","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"aTHbtQEYlw"}],"key":"mheapgprZw"}],"key":"pxKr5PWTUg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Create an array of electrode positions\nx = np.linspace(0, 47, 48)   # 48 electrodes, 1 m spacing\nprint(f\"Electrode positions: {x[:6]} ... {x[-3:]}\")\nprint(f\"Array shape: {x.shape}\")\n\n# Vectorised arithmetic — no loops needed\nrho_values = np.random.lognormal(mean=4.5, sigma=0.5, size=48)\nprint(f\"\\nMean apparent resistivity : {rho_values.mean():.1f} Ω·m\")\nprint(f\"Std  apparent resistivity : {rho_values.std():.1f} Ω·m\")","key":"AjHEze8onU"},{"type":"outputs","id":"LusllN8ZyXNh45busqiO7","children":[],"key":"IqHfTZp0Gd"}],"key":"lnHj7fArUd"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":156,"column":1},"end":{"line":156,"column":1}},"key":"YIs8ZpNWg0"},{"type":"heading","depth":2,"position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"children":[{"type":"text","value":"Matplotlib Quick Plot","position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"key":"pF4VXOD3hq"}],"identifier":"matplotlib-quick-plot","label":"Matplotlib Quick Plot","html_id":"matplotlib-quick-plot","implicit":true,"key":"eHeNivRRgy"}],"key":"tbzyAHC5V0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(figsize=(9, 3))\nax.plot(x, rho_values, 'o-', color='steelblue', markersize=4, linewidth=1)\nax.set_xlabel(\"Electrode position (m)\")\nax.set_ylabel(\"Apparent resistivity (Ω·m)\")\nax.set_title(\"Synthetic resistivity profile — Wenner array\")\nax.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"eVzbsZK5e7"},{"type":"outputs","id":"198TCtFjGIJXdKkj7hgZj","children":[],"key":"WnimPtF0eg"}],"key":"jDR8sNb4Lt"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"aPrkPgtJfc"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Summary","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"ih0LuCpERT"}],"key":"WqWxRsz0NF"},{"type":"paragraph","position":{"start":{"line":177,"column":1},"en