parent resistivity values\n\nprint(f\"Survey type       : {survey_type}\")\nprint(f\"Electrodes        : {num_electrodes}\")\nprint(f\"Resistivity (Ω·m) : {resistivity}\")\nprint(f\"Measurements      : {measurements}\")","key":"llerI0ATvz"},{"type":"outputs","id":"P5wjEdiPCSTajBEbWqMRW","children":[],"key":"FY9iIns10g"}],"key":"sA4A6PBDKJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the type of a variable\nprint(type(resistivity))\nprint(type(num_electrodes))\nprint(type(survey_type))\nprint(type(measurements))","key":"vdpIqW0JHp"},{"type":"outputs","id":"xX6_57tJNE5QnpCKBHbdL","children":[],"key":"SI5r8uJBva"}],"key":"fczA1uHTRy"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"fKWyyOzBgO"},{"type":"heading","depth":2,"position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"Control Structures","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"J2xYKEIxbg"}],"identifier":"control-structures","label":"Control Structures","html_id":"control-structures","implicit":true,"key":"yWeVUlrOL1"},{"type":"heading","depth":3,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"Conditionals","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"FyxdQ0PHe3"}],"identifier":"conditionals","label":"Conditionals","html_id":"conditionals","implicit":true,"key":"BDFQVbAsqE"}],"key":"Ub4wKV39AI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rho = 250  # Ohm·m\n\nif rho < 10:\n    print(\"Very conductive — possible clay or saline water\")\nelif rho < 100:\n    print(\"Moderately conductive — moist soil\")\nelif rho < 1000:\n    print(\"Resistive — dry soil or gravel\")\nelse:\n    print(\"Highly resistive — bedrock or dry sand\")","key":"Z7N3OjcGEo"},{"type":"outputs","id":"f2mnQnEE8KG3jHEdCktVl","children":[],"key":"H9TwCQN3SG"}],"key":"Qc5syhvLt3"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Loops","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"pr2VjArxtJ"}],"identifier":"loops","label":"Loops","html_id":"loops","implicit":true,"key":"lc70oyM2we"}],"key":"auSvPU4oV7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"electrode_positions = [0, 1, 2, 3, 4]  # metres\n\nfor i, pos in enumerate(electrode_positions):\n    print(f\"Electrode {i+1:2d}  →  x = {pos} m\")","key":"G4vem3ifq6"},{"type":"outputs","id":"D-8ru3o_5Tt8_NDJhzuwe","children":[],"key":"SbSuFDq1rm"}],"key":"L0Co7EFesV"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"key":"BJPtW1KIOr"},{"type":"heading","depth":2,"position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"Functions","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"VfatHbKvMr"}],"identifier":"functions","label":"Functions","html_id":"functions","implicit":true,"key":"aCwmHDm4lC"},{"type":"paragraph","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"Functions let you package reusable logic with a clear interface.","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"XAZu80cbEO"}],"key":"xTddQOxdgM"}],"key":"J8dBTuTidx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def apparent_resistivity(V, I, K):\n    \"\"\"\n    Calculate apparent resistivity.\n\n    Parameters\n    ----------\n    V : float\n        Measured voltage (V)\n    I : float\n        Applied current (A)\n    K : float\n        Geometric factor for the array (m)\n\n    Returns\n    -------\n    float\n        Apparent resistivity (Ω·m)\n    \"\"\"\n    return K * (V / I)\n\n# Wenner array with a = 1 m → K = 2πa\nimport math\na = 1.0          # electrode spacing (m)\nK_wenner = 2 * math.pi * a\n\nrho_a = apparent_resistivity(V=0.05, I=0.001, K=K_wenner)\nprint(f\"Apparent resistivity: {rho_a:.1f} Ω·m\")","key":"ukzKUNUBzD"},{"type":"outputs","id":"xX1VFHHhBW7qfr0pEbSHo","children":[],"key":"iUHAmhgPFw"}],"key":"AL6kiyYcqn"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":136,"column":1},"end":{"line":136,"column":1}},"key":"JvRIEIjrpJ"},{"type":"heading","depth":2,"position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"children":[{"type":"text","value":"NumPy Basics","position":{"start":{"line":138,"column":1},"end":{"line":138,"column":1}},"key":"OkwRPRk0mS"}],"identifier":"numpy-basics","label":"NumPy Basics","html_id":"numpy-basics","implicit":true,"key":"C2iI5ZZE28"},{"type":"paragraph","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"link","url":"https://numpy.org","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"text","value":"NumPy","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"JEeICZEJWM"}],"urlSource":"https://numpy.org","key":"is0JOc1xKR"},{"type":"text","value":" is the backbone of numerical computing in Python.","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"nmaC2rEptX"}],"key":"Nt79EOPxMx"}],"key":"B6OLKsm28C"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Create an array of electrode positions\nx = np.linspace(0, 47, 48)   # 48 electrodes, 1 m spacing\nprint(f\"Electrode positions: {x[:6]} ... {x[-3:]}\")\nprint(f\"Array shape: {x.shape}\")\n\n# Vectorised arithmetic — no loops needed\nrho_values = np.random.lognormal(mean=4.5, sigma=0.5, size=48)\nprint(f\"\\nMean apparent resistivity : {rho_values.mean():.1f} Ω·m\")\nprint(f\"Std  apparent resistivity : {rho_values.std():.1f} Ω·m\")","key":"kcQfYbESMV"},{"type":"outputs","id":"10YUs25gUof8J4RRdEepm","children":[],"key":"ITvDAJyaoL"}],"key":"JitSpqvalR"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":156,"column":1},"end":{"line":156,"column":1}},"key":"S6Rw9EEIRF"},{"type":"heading","depth":2,"position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"children":[{"type":"text","value":"Matplotlib Quick Plot","position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"key":"k58EkdwQ79"}],"identifier":"matplotlib-quick-plot","label":"Matplotlib Quick Plot","html_id":"matplotlib-quick-plot","implicit":true,"key":"VN0z318Cst"}],"key":"vl7f44W8qS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(figsize=(9, 3))\nax.plot(x, rho_values, 'o-', color='steelblue', markersize=4, linewidth=1)\nax.set_xlabel(\"Electrode position (m)\")\nax.set_ylabel(\"Apparent resistivity (Ω·m)\")\nax.set_title(\"Synthetic resistivity profile — Wenner array\")\nax.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.show()","key":"kBAj6K1vuu"},{"type":"outputs","id":"L8ACJsslvieHGBK04LsVu","children":[],"key":"XrcaYy68Me"}],"key":"U4VvNiuYqv"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"aYOCsY96UB"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Summary","position":{"start":{"line":175,"column":1},"end":{"line":175,"column":1}},"key":"BlOUV7i8f1"}],"key":"dkmDmn5XSH"},{"type":"paragraph","position":{"start":{"line":177,"column":1},"en