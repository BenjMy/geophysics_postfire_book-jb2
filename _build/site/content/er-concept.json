nd":{"line":53,"column":1}},"children":[{"type":"text","value":"🎛️ Interactive Explorer — Ohm’s Law","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"Tj3k9dbT1H"}],"identifier":"id-interactive-explorer-ohms-law","label":"🎛️ Interactive Explorer — Ohm’s Law","html_id":"id-interactive-explorer-ohms-law","implicit":true,"key":"oYFzSyIuqO"},{"type":"paragraph","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"Adjust resistivity, length and cross-section to see how resistance changes:","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"xwk4pXSpUn"}],"key":"pBdybUx2Sb"}],"key":"w1Wp4XdzmB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def ohm_widget():\n    rho_slider = widgets.FloatLogSlider(\n        value=50, base=10, min=0, max=6,\n        step=0.05, description='ρ (Ω·m)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    L_slider = widgets.FloatSlider(\n        value=1.0, min=0.1, max=10.0, step=0.1,\n        description='L (m)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    A_slider = widgets.FloatSlider(\n        value=1.0, min=0.01, max=5.0, step=0.01,\n        description='A (m²)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    out = widgets.Output()\n\n    def update(change=None):\n        R = rho_slider.value * L_slider.value / A_slider.value\n        sigma = 1 / rho_slider.value\n        with out:\n            out.clear_output(wait=True)\n            print(f\"  Resistance  R = {R:.4f} Ω\")\n            print(f\"  Conductivity σ = {sigma:.6f} S/m\")\n\n    rho_slider.observe(update, names='value')\n    L_slider.observe(update, names='value')\n    A_slider.observe(update, names='value')\n    update()\n\n    display(w