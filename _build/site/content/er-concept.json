{"version":3,"kind":"Notebook","sha256":"13b529336ff7d82da5a6634cde20f637810a46e023f103301b022ddc148bffc3","slug":"er-concept","location":"/notebooks/02_resistivity/012_ER_concept.md","dependencies":[],"frontmatter":{"title":"Electrical Resistivity","kernelspec":{"name":"python3","display_name":"Python 3 (Geophysics)","language":"python"},"authors":[{"nameParsed":{"literal":"Benjamin Mary","given":"Benjamin","family":"Mary"},"name":"Benjamin Mary","orcid":"0000-0000-0000-0000","corresponding":true,"email":"benjamin.mary@ica.csic.es","affiliations":["uni"],"id":"contributors-myst-generated-uid-0"}],"date":"2025-01-19","doi":"10.5281/zenodo.0000000","license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true},"code":{"id":"MIT","url":"https://opensource.org/licenses/MIT","name":"MIT License","free":true,"osi":true}},"github":"https://github.com/BenjMy/geophysics_postfire_book-jb2","binder":"https://mybinder.org/v2/gh/BenjMy/geophysics_postfire_book-jb2/main","keywords":["geophysics","electrical resistivity tomography","electromagnetic induction","python","resipy","emagpy","open education"],"copyright":"2025","affiliations":[{"id":"uni","name":"CSIC","department":"ICA","city":"Madrid","country":"Spain"}],"settings":{"output_stderr":"show"},"numbering":{"title":{"offset":2}},"source_url":"https://github.com/BenjMy/geophysics_postfire_book-jb2/blob/main/notebooks/02_resistivity/012_ER_concept.md","edit_url":"https://github.com/BenjMy/geophysics_postfire_book-jb2/edit/main/notebooks/02_resistivity/012_ER_concept.md","thumbnail":"/resistivity_table1-39ee376280471bd4845c7a8aae5d1826.png","exports":[{"format":"md","filename":"012_ER_concept.md","url":"/012_ER_concept-1b3e0f70797e1dd3e731304e5144b699.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Learn