 style=\"height:3em;\"></span><span class=\"frac-line\" style=\"border-bottom-width:0.04em;\"></span></span><span style=\"top:-3.677em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\">L</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.686em;\"><span></span></span></span></span></span><span class=\"mclose nulldelimiter\"></span></span></span></span></span></span>","enumerator":"2","key":"QSc6MEnsKN"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"where ","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"lvTS6VbUkS"},{"type":"inlineMath","value":"R","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>R</mi></mrow><annotation encoding=\"application/x-tex\">R</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.00773em;\">R</span></span></span></span>","key":"fBvBzjqeB2"},{"type":"text","value":" is resistance (Ω). Rearranging:","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"GR76Jfpc6M"}],"key":"ThGlWKKumU"},{"type":"math","value":"\\rho = R \\frac{A}{L}","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"html":"<span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\" display=\"block\"><semantics><mrow><mi>ρ</mi><mo>=</mo><mi>R</mi><mfrac><mi>A</mi><mi>L</mi></mfrac></mrow><annotation encoding=\"application/x-tex\">\\rho = R \\frac{A}{L}</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.625em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\">ρ</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:2.0463em;vertical-align:-0.686em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.00773em;\">R</span><span class=\"mord\"><span class=\"mopen nulldelimiter\"></span><span class=\"mfrac\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:1.3603em;\"><span style=\"top:-2.314em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\">L</span></span></span><span style=\"top:-3.23em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"frac-line\" style=\"border-bottom-width:0.04em;\"></span></span><span style=\"top:-3.677em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\">A</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.686em;\"><span></span></span></span></span></span><span class=\"mclose nulldelimiter\"></span></span></span></span></span></span>","enumerator":"3","key":"HzySyJMaux"}],"key":"MuK1uP7Hik"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nimport ipywidgets as widgets\nfrom IPython.display import display\n\ndef resistance(rho, L, A):\n    \"\"\"Ohm's Law: resistance of a homogeneous cylinder.\"\"\"\n    return rho * L / A\n\n# Example: a 1 m³ cube of moist loam (rho ≈ 50 Ω·m)\nrho_loam = 50   # Ω·m\nR = resistance(rho_loam, L=1.0, A=1.0)\nprint(f\"\\033[96mResistance of 1 m3 loam cube : {R:.1f} Ω\\033[0m\")","visibility":"remove","key":"bvHbe9LwLU"},{"type":"outputs","id":"2G9QYzZiQ8LBX1Le5_elQ","children":[],"visibility":"show","key":"hP0wrcxHBy"}],"data":{"tags":[]},"visibility":"show","key":"RAGJDJMNz0"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"children":[{"type":"text","value":"Adjust resistivity, length and cross-section to see how resistance changes:","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"key":"tRibOho6KD"}],"key":"qHSyPMC3vw"}],"key":"uZft9T9MkL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import ipywidgets as widgets\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.colors as mcolors\nimport numpy as np\n\ndef resistance_widget():\n    style  = {'description_width': '80px'}\n    layout = widgets.Layout(width='450px')\n\n    rho_slider = widgets.FloatLogSlider(\n        value=50, base=10, min=0, max=6, step=0.05,\n        description='ρ (Ω·m)', style=style, layout=layout)\n    L_slider = widgets.FloatSlider(\n        value=1.0, min=0.1, max=10.0, step=0.1,\n        description='L (m)', style=style, layout=layout)\n    A_slider = widgets.FloatSlider(\n        value=1.0, min=0.01, max=5.0, step=0.01,\n        description='A (m²)', style=style, layout=layout)\n\n    out = widgets.Output()\n\n    def update(change=None):\n        rho = rho_slider.value\n        L   = L_slider.value\n        A   = A_slider.value\n        R   = rho * L / A\n        sigma = 1.0 / rho\n        side  = np.sqrt(A)          # side length of square cross-section\n\n        with out:\n            out.clear_output(wait=True)\n\n            fig, axes = plt.subplots(1, 2, figsize=(10, 4))\n\n            # ── Left: 3D-style sketch of the resistive element ──────────────\n            ax = axes[0]\n            ax.set_xlim(0, 10)\n            ax.set_ylim(0, 6)\n            ax.set_aspect('equal')\n            ax.axis('off')\n\n            # Normalise rho to a colour (low=blue/conductive, high=red/resistive)\n            norm     = mcolors.LogNorm(vmin=1, vmax=1e6)\n            cmap     = plt.cm.RdYlBu_r\n            face_col = cmap(norm(rho))\n\n            # Draw cuboid (isometric-style): front face + top face + right face\n            w = min(max(side * 0.8, 0.5), 3.5)   # visual width (capped)\n            h = min(max(side * 0.8, 0.5), 3.5)   # visual height (capped)\n            d = min(max(L   * 0.6, 0.5), 5.0)    # visual depth = L\n\n            ox, oy = 1.5, 1.0   # origin\n\n            # Front face\n            front = mpatches.FancyBboxPatch(\n                (ox, oy), w, h,\n                boxstyle='square,pad=0',\n                facecolor=face_col, edgecolor='k', linewidth=1.5, zorder=2)\n            ax.add_patch(front)\n\n            # Top face (parallelogram)\n            top_x = [ox, ox+w, ox+w+d*0.4, ox+d*0.4, ox]\n            top_y = [oy+h, oy+h, oy+h+d*0.3, oy+h+d*0.3, oy+h]\n            ax.fill(top_x, top_y, color=mcolors.to_rgba(face_col, 0.7),\n                    edgecolor='k', linewidth=1.5, zorder=2)\n\n            # Right face (parallelogram)\n            right_x = [ox+w, ox+w+d*0.4, ox+w+d*0.4, ox+w, ox+w]\n            right_y = [oy, oy+d*0.3, oy+h+d*0.3, oy+h, oy]\n            ax.fill(right_x, right_y, color=mcolors.to_rgba(face_col, 0.5),\n                    edgecolor='k', linewidth=1.5, zorder=2)\n\n            # Dimension arrows & labels\n            # L arrow (along depth direction)\n            ax.annotate('', xy=(ox+d*0.4+0.1, oy-0.4),\n                        xytext=(ox+0.0, oy-0.4),\n                        arrowprops=dict(arrowstyle='<->', color='k', lw=1.5))\n            ax.text(ox + d*0.2, oy-0.7, f'L = {L:.1f} m',\n                    ha='center', fontsize=10, fontstyle='italic')\n\n            # Colourbar for ρ\n            sm = plt.cm.ScalarMappable(cmap=cmap, norm=norm)\n            sm.set_array([])\n            cbar = fig.colorbar(sm, ax=ax, orientation='vertical',\n                                fraction=0.03, pad=0.02,\n                                label='ρ (Ω·m)')\n            cbar.ax.tick_params(labelsize=8)\n\n            ax.set_title('Resistive element geometry', fontsize=11, pad=8)\n\n            # ── Right: result summary ────────────────────────────────────────\n            ax2 = axes[1]\n            ax2.axis('off')\n\n            lines = [\n                ('Equation',        r'$R = \\rho \\cdot \\dfrac{L}{A}$',  14, 'black'),\n                ('',                '',                                   8, 'black'),\n                ('ρ (resistivity)', f'{rho:.2e} Ω·m',                   12, '#c0392b'),\n                ('L (length)',      f'{L:.2f} m',                        12, '#2980b9'),\n                ('A (cross-sect.)', f'{A:.4f} m²',                       12, '#27ae60'),\n                ('',                '',                                    8, 'black'),\n                ('R (resistance)',  f'{R:.4f} Ω',                        14, 'black'),\n                ('σ (conductivity)',f'{sigma:.2e} S/m',                  12, '#7f8c8d'),\n            ]\n\n            y = 0.92\n            for label, value, fs, col in lines:\n                if label == '':\n                    y -= 0.04\n                    continue\n                ax2.text(0.05, y, f'{label}:', fontsize=fs,\n                         transform=ax2.transAxes, color='#555')\n                ax2.text(0.55, y, value, fontsize=fs, fontweight='bold',\n                         transform=ax2.transAxes, color=col)\n                y -= 0.13\n\n            # Note clarifying terminology\n            ax2.text(0.05, 0.04,\n                     '⚠ R = ρ·L/A is the resistance equation,\\n'\n                     '   not Ohm\\'s law (V = R·I)',\n                     fontsize=8, color='#888',\n                     transform=ax2.transAxes, style='italic')\n\n            plt.tight_layout()\n            plt.show()\n\n    rho_slider.observe(update, names='value')\n    L_slider.observe(update, names='value')\n    A_slider.observe(update, names='value')\n    update()\n\n    display(widgets.VBox([\n        widgets.HTML(\n            \"<b>Resistance equation — R = ρ · L / A</b>\"\n            \"<br><small style='color:grey'>Ohm's law is V = R·I — \"\n            \"this widget shows how geometry and material control R</small>\"),\n        rho_slider, L_slider, A_slider, out\n    ]))\n\nresistance_widget()","visibility":"remove","key":"VZPRsMyITK"},{"type":"outputs","id":"Nf4WbS-4PtxwxlA61JZC4","children":[],"visibility":"show","key":"Wl4KbHjFVp"}],"data":{"tags":[]},"visibility":"show","key":"GYg8n29dQF"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":197,"column":1},"end":{"line":197,"column":1}},"key":"P5Sld4LVuI"},{"type":"heading","depth":2,"position":{"start":{"line":199,"column":1},"end":{"line":199,"column":1}},"children":[{"type":"text","value":"Typical resistivity values","position":{"start":{"line":199,"column":1},"end":{"line":199,"column":1}},"key":"rAGoGPQqzw"}],"identifier":"typical-resistivity-values","label":"Typical resistivity values","html_id":"typical-resistivity-values","implicit":true,"key":"VdGvUPBU3P"},{"type":"paragraph","position":{"start":{"line":201,"column":1},"end":{"line":201,"column":1}},"children":[{"type":"text","value":"See the ","position":{"start":{"line":201,"column":1},"end":{"line":201,"column":1}},"key":"mnWidS6Gl8"},{"type":"link","url":"https://em.geosci.xyz/content/physical_properties/electrical_conductivity/electrical_conductivity_values.html","position":{"start":{"line":201,"column":1},"end":{"line":201,"column":1}},"children":[{"type":"text","value":"EMGeoSci reference table","position":{"start":{"line":201,"column":1},"end":{"line":201,"column":1}},"key":"k7BVFcEiTP"}],"urlSource":"https://em.geosci.xyz/content/physical_properties/electrical_conductivity/electrical_conductivity_values.html","key":"v0zQRmtZRA"},{"type":"text","value":" for a comprehensive overview of resistivity ranges for common earth materials.","position":{"start":{"line":201,"column":1},"end":{"line":201,"column":1}},"key":"KIHX1SRnyY"}],"key":"bNFjPYDlFX"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/resistivity_table1-39ee376280471bd4845c7a8aae5d1826.png","alt":"Overview of resistivity ranges for common earth materials (EMGeoSci reference table).","width":"100%","align":"center","data":{"altTextIsAutoGenerated":true},"key":"ibHRzc1uVd","urlSource":"../../assets/images/resistivity_table1.png"},{"type":"caption","children":[{"type":"paragraph","position":{"start":{"line":207,"column":1},"end":{"line":207,"column":1}},"children":[{"type":"captionNumber","kind":"figure","label":"fig-timeline-2","identifier":"fig-timeline-2","html_id":"fig-timeline-2","enumerator":"8","children":[{"type":"text","value":"Figure ","key":"V2nLetBkaJ"},{"type":"text","value":"8","key":"MRBbWr4e6P"},{"type":"text","value":":","key":"trR5gSLz9O"}],"template":"Figure %s:","key":"lT2N6ZIyEU"},{"type":"text","value":"Overview of resistivity ranges for common earth materials (EMGeoSci reference table).","position":{"start":{"line":207,"column":1},"end":{"line":207,"column":1}},"key":"WEjSgMy9Wn"}],"key":"IDj69FiIW4"}],"key":"i77LNo3DMh"}],"label":"fig-timeline-2","identifier":"fig-timeline-2","enumerator":"1","html_id":"fig-timeline-2","key":"z6bcomnohh"}],"key":"Bj9aXtUI4W"}],"key":"rvftMVdewM"},"references":{"cite":{"order":[],"data":{}}}}