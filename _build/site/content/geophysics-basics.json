0.8333em;vertical-align:-0.15em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07153em;\">K</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.3283em;\"><span style=\"top:-2.55em;margin-left:-0.0715em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\"><span class=\"mord mathnormal mtight\" style=\"margin-right:0.13889em;\">W</span><span class=\"mord mathnormal mtight\">e</span><span class=\"mord mathnormal mtight\">nn</span><span class=\"mord mathnormal mtight\" style=\"margin-right:0.02778em;\">er</span></span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.15em;\"><span></span></span></span></span></span></span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">2</span><span class=\"mord mathnormal\">πa</span></span></span></span></span>","enumerator":"5","key":"HQaIe6MxGI"}],"key":"MVkY8ETyIY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def wenner_apparent_resistivity(V_mn, I_ab, a):\n    \"\"\"\n    Compute apparent resistivity for a Wenner array.\n\n    Parameters\n    ----------\n    V_mn : array-like  Measured voltage (V)\n    I_ab : float       Injected current (A)\n    a    : float       Electrode spacing (m)\n\n    Returns\n    -------\n    np.ndarray  Apparent resistivity (Ω·m)\n    \"\"\"\n    K = 2 * np.pi * a\n    return K * np.asarray(V_mn) / I_ab\n\n# Simulate a simple measurement\na = 2.0     # m — electrode spacing\nI = 0.1     # A — injected current\n\n# Synthetic voltages for a uniform half-space (rho = 100 Ω·m)\nrho_true = 100  # Ω·m\nK = 2 * np.pi * a\nV_synthetic = rho_true * I / K\n\nrho_a = wenner_apparent_resistivity(V_synthetic, I, a)\nprint(f\"Geometric factor K = {K:.3f} m\")\nprint(f\"Voltage measured   = {V_synthetic*1000:.3f} mV\")\nprint(f\"Apparent resist.   = {rho_a:.1f} Ω·m  (should equal {rho_true} Ω·m for uniform half-space)\")","visibility":"hide","key":"fW1flBVkHW"},{"type":"outputs","id":"KDAUvt6ATA1ADQmWDLvS3","children":[],"visibility":"show","key":"oXCC8u3q3u"}],"data":{"tags":[]},"visibility":"show","key":"IGKNDJQqoD"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":226,"column":1},"end":{"line":226,"column":1}},"children":[{"type":"text","value":"🎛️ Interactive Explorer — Wenner Array","position":{"start":{"line":226,"column":1},"end":{"line":226,"column":1}},"key":"W9lzVkfzrF"}],"identifier":"id-interactive-explorer-wenner-array","label":"🎛️ Interactive Explorer — Wenner Array","html_id":"id-interactive-explorer-wenner-array","implicit":true,"key":"PGsignhPaI"},{"type":"paragraph","position":{"start":{"line":228,"column":1},"end":{"line":228,"column":1}},"children":[{"type":"text","value":"Adjust electrode spacing, current and true resistivity to explore the measurement:","position":{"start":{"line":228,"column":1},"end":{"line":228,"column":1}},"key":"URjv7JXTWE"}],"key":"VVO6r0FZ1B"}],"key":"Flf0zofRen"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def wenner_widget():\n    rho_slider = widgets.FloatLogSlider(\n        value=100, base=10, min=0, max=4,\n        step=0.05, description='ρ true (Ω·m)',\n        style={'description_width': '110px'},\n        layout=widgets.Layout(width='450px')\n    )\n    a_slider = widgets.FloatSlider(\n        value=2.0, min=0.5, max=10.0, step=0.5,\n        description='Spacing a (m)',\n        style={'description_width': '110px'},\n        layout=widgets.Layout(width='450px')\n    )\n    I_slider = widgets.FloatSlider(\n        value=0.1, min=0.01, max=1.0, step=0.01,\n        description='Current I (A)',\n        style={'description_width': '110px'},\n        layout=widgets.Layout(width='450px')\n    )\n    out = widgets.Output()\n\n    def update(change=None):\n        rho = rho_slider.value\n        a   = a_slider.value\n        I   = I_slider.value\n        K   = 2 * np.pi * a\n        V   = rho * I / K\n        rho_a = wenner_apparent_resistivity(V, I, a)\n        with out:\n            out.clear_output(wait=True)\n            print(f\"  Geometric factor  K  = {K:.3f} m\")\n            print(f\"  Voltage measured  V  = {V*1000:.4f} mV\")\n            print(f\"  Apparent resist. ρₐ  = {rho_a:.1f} Ω·m\")\n\n    rho_slider.observe(update, names='value')\n    a_slider.observe(update, names='value')\n    I_slider.observe(update, names='value')\n    update()\n\n    display(widgets.VBox([\n        widgets.HTML(\"<b>Wenner array — ρₐ = K · V / I &nbsp;&nbsp; K = 2πa</b>\"),\n        rho_slider, a_slider, I_slider, out\n    ]))\n\nwenner_widget()","visibility":"hide","key":"ngN4uqmtzz"},{"type":"outputs","id":"OmH9NV_p-NJkAif7kanLz","children":[],"visibility":"show","key":"gdc7sO6zel"}],"data":{"tags":[]},"visibility":"show","key":"znNethEt0A"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":279,"column":1},"end":{"line":279,"column":1}},"key":"MBDHdjtDzt"},{"type":"heading","depth":2,"position":{"start":{"line":281,"column":1},"end":{"line":281,"column":1}},"children":[{"type":"text","value":"Electrode Geometry Diagram","position":{"start":{"line":281,"column":1},"end":{"line":281,"column":1}},"key":"rcJTHofP53"}],"identifier":"electrode-geometry-diagram","label":"Electrode Geometry Diagram","html_id":"electrode-geometry-diagram","implicit":true,"key":"o7WfU0H4xq"}],"key":"DUbykeoT7g"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(figsize=(9, 3))\n\n# Ground surface\nax.axhline(0, color='saddlebrown', linewidth=2, label='Ground surface')\nax.fill_between([-1, 10], 0, -2, color='wheat', alpha=0.4)\n\npositions = {'A': 0, 'M': 2, 'N': 4, 'B': 6}\ncolours   = {'A': 'firebrick', 'M': 'steelblue', 'N': 'steelblue', 'B': 'firebrick'}\nroles     = {'A': 'Current +', 'M': 'Potential +', 'N': 'Potential −', 'B': 'Current −'}\n\nfor label, x in positions.items():\n    ax.plot(x, 0, 'v', markersize=14, color=colours[label])\n    ax.text(x, 0.25, label, ha='center', fontsize=12, fontweight='bold', color=colours[label])\n    ax.text(x, -0.55, roles[label], ha='center', fontsize=8, color='gray')\n\n# Spacing annotations\nfor (x0, x1), txt in [((0, 2), 'a'), ((2, 4), 'a'), ((4, 6), 'a')]:\n    ax.annotate('', xy=(x1, -0.85), xytext=(x0, -0.85),\n                arrowprops=dict(arrowstyle='<->', color='k'))\n    ax.text((x0 + x1) / 2, -1.1, txt, ha='center', fontsize=10)\n\nax.set_xlim(-1, 7)\nax.set_ylim(-1.5, 1.0)\nax.set_aspect('equal')\nax.axis('off')\nax.set_title(\"Wenner array — equal electrode spacing $a$\", pad=12)\nplt.tight_layout()\nplt.show()","visibility":"hide","key":"FBdq3ERUi5"},{"type":"outputs","id":"4EaSqLOko2Hd0zY305Qt9","children":[],"visibility":"show","key":"u3vdhCATER"}],"data":{"tags":[]},"visibility":"show","key":"GLLnR86dlw"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":315,"column":1},"end":{"line":315,"column":1}},"children":[{"type":"text","value":"🎛️ Interactive Explorer — Array Geometry","position":{"start":{"line":315,"column":1},"end":{"line":315,"column":1}},"key":"jv3Lb3FHoT"}],"identifier":"id-interactive-explorer-array-geometry","label":"🎛️ Interactive Explorer — Array Geometry","html_id":"id-interactive-explorer-array-geometry","implicit":true,"key":"aaJXL3oWoB"},{"type":"paragraph","position":{"start":{"line":317,"column":1},"end":{"line":317,"column":1}},"children":[{"type":"text","value":"Move the sliders to see how changing spacing ","position":{"start":{"line":317,"column":1},"end":{"line":317,"column":1}},"key":"VkNGrfeXsg"},{"type":"inlineMath","value":"a","position":{"start":{"line":317,"column":1},"end":{"line":317,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>a</mi></mrow><annotation encoding=\"application/x-tex\">a</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\">a</span></span></span></span>","key":"tbqsTXJxKU"},{"type":"text","value":" shifts the electrode positions and updates the geometric factor:","position":{"start":{"line":317,"column":1},"end":{"line":317,"column":1}},"key":"Dld1OIxjLO"}],"key":"SzpLfHdN20"}],"key":"l2GoIXGIi0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def geometry_widget():\n    a_slider = widgets.FloatSlider(\n        value=2.0, min=0.5, max=5.0, step=0.5,\n        description='Spacing a (m)',\n        style={'description_width': '110px'},\n        layout=widgets.Layout(width='400px')\n    )\n    out = widgets.Output()\n\n    def update(change=None):\n        a = a_slider.value\n        K = 2 * np.pi * a\n        with out:\n            out.clear_output(wait=True)\n            fig, ax = plt.subplots(figsize=(9, 2.8))\n            ax.axhline(0, color='saddlebrown', linewidth=2)\n            ax.fill_between([-1, 4*a + 1], 0, -2, color='wheat', alpha=0.4)\n\n            pos = {'A': 0, 'M': a, 'N': 2*a, 'B': 3*a}\n            cols = {'A': 'firebrick', 'M': 'steelblue', 'N': 'steelblue', 'B': 'firebrick'}\n            role = {'A': 'Current +', 'M': 'Potential +', 'N': 'Potential −', 'B': 'Current −'}\n\n            for lbl, x in pos.items():\n                ax.plot(x, 0, 'v', markersize=14, color=cols[lbl])\n                ax.text(x, 0.25, lbl, ha='center', fontsize=12,\n                        fontweight='bold', color=cols[lbl])\n                ax.text(x, -0.5, role[lbl], ha='center', fontsize=8, color='gray')\n\n            for (x0, x1), txt in [((0, a), 'a'), ((a, 2*a), 'a'), ((2*a, 3*a), 'a')]:\n                ax.annotate('', xy=(x1, -0.8), xytext=(x0, -0.8),\n                            arrowprops=dict(arrowstyle='<->', color='k'))\n                ax.text((x0+x1)/2, -1.05, f'{a} m', ha='center', fontsize=9)\n\n            ax.set_xlim(-0.5, 3*a + 0.5)\n            ax.set_ylim(-1.4, 0.8)\n            ax.axis('off')\n            ax.set_title(f\"Wenner array  |  a = {a} m  |  K = 2πa = {K:.2f} m\", pad=10)\n            plt.tight_layout()\n            plt.show()\n\n    a_slider.observe(update, names='value')\n    update()\n    display(widgets.VBox([a_slider, out]))\n\ngeometry_widget()","visibility":"hide","key":"cC3f9SgmDA"},{"type":"outputs","id":"fp81At2MAkvkb0JTGPv0S","children":[],"visibility":"show","key":"tBPe14v6y8"}],"data":{"tags":[]},"visibility":"show","key":"xOBf8QYKQF"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":369,"column":1},"end":{"line":369,"column":1}},"children":[{"type":"text","value":"True space VS Model space","position":{"start":{"line":369,"column":1},"end":{"line":369,"column":1}},"key":"WjD7FizDf0"}],"identifier":"true-space-vs-model-space","label":"True space VS Model space","html_id":"true-space-vs-model-space","implicit":true,"key":"hxLF6yd4Tz"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/image1-2_Dimechetal-3cb6851758dac422eedc65ae3f568792.png","alt":"Temporal dynamics of key soil properties following wildfire (after Dimech et al.). Shaded zones indicate the three intervention windows: emergency (red), early recovery (orange), and late recovery (green).","width":"75%","align":"center","data":{"altTextIsAutoGenerated":true},"key":"Sqg95BMp5W","urlSource":"../../assets/images/image1-2_Dimechetal.png"},{"type":"caption","