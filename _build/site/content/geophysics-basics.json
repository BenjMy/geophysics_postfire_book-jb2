ht:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:2.0463em;vertical-align:-0.686em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.00773em;\">R</span><span class=\"mord\"><span class=\"mopen nulldelimiter\"></span><span class=\"mfrac\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:1.3603em;\"><span style=\"top:-2.314em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\">L</span></span></span><span style=\"top:-3.23em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"frac-line\" style=\"border-bottom-width:0.04em;\"></span></span><span style=\"top:-3.677em;\"><span class=\"pstrut\" style=\"height:3em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\">A</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.686em;\"><span></span></span></span></span></span><span class=\"mclose nulldelimiter\"></span></span></span></span></span></span>","enumerator":"3","key":"ZCUhksS6zI"}],"key":"x3RUGotn3R"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nimport ipywidgets as widgets\nfrom IPython.display import display\n\ndef resistance(rho, L, A):\n    \"\"\"Ohm's Law: resistance of a homogeneous cylinder.\"\"\"\n    return rho * L / A\n\n# Example: a 1 m³ cube of moist loam (rho ≈ 50 Ω·m)\nrho_loam = 50   # Ω·m\nR = resistance(rho_loam, L=1.0, A=1.0)\nprint(f\"Resistance of 1 m³ loam cube : {R:.1f} Ω\")","visibility":"hide","key":"gQYwoPiNH9"},{"type":"outputs","id":"3Dc1yoc-ia2C0PYtVWepe","children":[],"visibility":"show","key":"uxN4JMd8wL"}],"data":{"tags":[]},"visibility":"show","key":"ng1QJTFGQk"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"text","value":"🎛️ Interactive Explorer — Ohm’s Law","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"t7D7gfufeH"}],"identifier":"id-interactive-explorer-ohms-law","label":"🎛️ Interactive Explorer — Ohm’s Law","html_id":"id-interactive-explorer-ohms-law","implicit":true,"key":"G5EAgReuPW"},{"type":"paragraph","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"Adjust resistivity, length and cross-section to see how resistance changes:","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"hCMfKiY1vI"}],"key":"q4JFxXmygN"}],"key":"Tfw7jAtLNg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def ohm_widget():\n    rho_slider = widgets.FloatLogSlider(\n        value=50, base=10, min=0, max=6,\n        step=0.05, description='ρ (Ω·m)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    L_slider = widgets.FloatSlider(\n        value=1.0, min=0.1, max=10.0, step=0.1,\n        description='L (m)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    A_slider = widgets.FloatSlider(\n        value=1.0, min=0.01, max=5.0, step=0.01,\n        description='A (m²)',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='450px')\n    )\n    out = widgets.Output()\n\n    def update(change=None):\n        R = rho_slider.value * L_slider.value / A_slider.value\n        sigma = 1 / rho_slider.value\n        with out:\n            out.clear_output(wait=True)\n            print(f\"  Resistance  R = {R:.4f} Ω\")\n            print(f\"  Conductivity σ = {sigma:.6f} S/m\")\n\n    rho_slider.observe(update, names='value')\n    L_slider.observe(update, names='value')\n    A_slider.observe(update, names='value')\n    update()\n\n    display(widgets.VBox([\n        widgets.HTML(\"<b>Ohm's Law — R = ρ · L / A</b>\"),\n        rho_slider, L_slider, A_slider, out\n    ]))\n\nohm_widget()","visibility":"hide","key":"lDKUHzvUou"},{"type":"outputs","id":"bJtgSeEt5ukOF3JyRi-HW","children":[],"visibility":"show","key":"zKtZ4qEymz"}],"data":{"tags":[]},"visibility":"show","key":"OsZWFOp0QX"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"EbdMTdoGro"},{"type":"heading","depth":2,"position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"children":[{"type":"text","value":"Typical Resistivity Values","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"lrMv79YpGL"}],"identifier":"typical-resistivity-values","label":"Typical Resistivity Values","html_id":"typical-resistivity-values","implicit":true,"key":"hGSvZMcpXv"}],"key":"nK5uPirCcL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"materials = {\n    \"Seawater\"          : (0.2,   1),\n    \"Clay\"              : (1,    20),\n    \"Groundwater\"       : (10,  100),\n    \"Moist soil\"        : (20,  200),\n    \"Dry sand / gravel\" : (200, 2000),\n    \"Limestone\"         : (500, 10000),\n    \"Granite\"           : (1e4, 1e6),\n}\n\nfig, ax = plt.subplots(figsize=(9, 4))\nfor i, (mat, (lo, hi)) in enumerate(materials.items()):\n    ax.barh(i, np.log10(hi) - np.log10(lo),\n            left=np.log10(lo), height=0.6,\n            color=plt.cm.RdYlBu_r(i / len(materials)), edgecolor='k', linewidth=0.5)\n    ax.text(np.log10(lo) - 0.05, i, mat, ha='right', va='center', fontsize=9)\n\nax.set_xlabel(\"log₁₀(Resistivity / Ω·m)\")\nax.set_title(\"Typical resistivity ranges for earth materials\")\nax.set_yticks([])\nax.set_xlim(-1, 7)\nax.grid(axis='x', alpha=0.3)\nplt.tight_layout()\nplt.show()","visibility":"hide","key":"VdDSKVgIuZ"},{"type":"outputs","id":"uDgoqLhYT3-gyBxgzXO9X","children":[],"visibility":"show","key":"G2ywJLB0wy"}],"data":{"tags":[]},"visibility":"show","key":"qmFWX7qDpz"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"children":[{"type":"text","value":"🎛️ Interactive Explorer — Material Resistivity","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"key":"WQ3uuuujJv"}],"identifier":"id-interactive-explorer-material-resistivity","label":"🎛️ Interactive Explorer — Material Resistivity","html_id":"id-interactive-explorer-material-resistivity","implicit":true,"key":"bgPJsryTsu"},{"type":"paragraph","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Hover over a material to highlight its range, or select one to see its typical properties:","position":{"start":{"line":135,"column":1},"end":{"line":135,"column":1}},"key":"sdBbXwWiPr"}],"key":"QQSXkBjKjf"}],"key":"zrrWRXsgq5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def material_widget():\n    mat_names = list(materials.keys())\n    dropdown = widgets.Dropdown(\n        options=mat_names,\n        value='Moist soil',\n        description='Material:',\n        style={'description_width': '80px'},\n        layout=widgets.Layout(width='350px')\n    )\n    out = widgets.Output()\n\n    def update(change=None):\n        mat = dropdown.value\n        lo, hi = materials[mat]\n        sigma_lo = 1 / hi\n        sigma_hi = 1 / lo\n        with out:\n            out.clear_output(wait=True)\n            fig, ax = plt.subplots(figsize=(8, 1.8))\n            for i, (m, (l, h)) in enumerate(materials.items()):\n                color = 'steelblue' if m == mat else 'lightgrey'\n                ax.barh(0, np.log10(h) - np.log10(l),\n                        left=np.log10(l), height=0.5,\n                        color=color, edgecolor='k', linewidth=0.4, alpha=0.9)\n            ax.set_xlabel(\"log₁₀(ρ / Ω·m)\")\n            ax.set_yticks([])\n            ax.set_xlim(-1, 7)\n            ax.set_title(f\"{mat}   |   ρ: {lo}–{hi} Ω·m   |   σ: {sigma_lo:.2e}–{sigma_hi:.2e} S/m\")\n            ax.grid(axis='x', alpha=0.3)\n            plt.tight_layout()\n            plt.show()\n\n    dropdown.observe(update, names='value')\n    update()\n    display(widgets.VBox([dropdown, out]))\n\nmaterial_widget()","visibility":"hide","key":"kJozSoPjpA"},{"type":"outputs","id":"xY0sqxNNgIqwjmn36namz","children":[],"visibility":"show","key":"BqtvZUXnZq"}],"data":{"tags":[]},"visibility":"show","key":"uBOKtbdS5D"},{"type":"block","children":[{"type":"thematicBreak","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"key":"bN0teEXu3v"},{"type":"heading","depth":2,"position":{"start":{"line":180,"column":1},"end":{"line":180,"column":1}},"children":[{"type":"text","value":"The 4-Electrode (Wenner) Array","position":{"start":{"line":180,"column":1},"end":{"line":180,"column":1}},"key":"OrKT8krXlp"}],"identifier":"the-4-electrode-wenner-array","label":"The 4-Electrode (Wenner) Array","html_id":"the-4-electrode-wenner-array","implicit":true,"key":"h4jqQvUYSg"},{"type":"paragraph","position":{"start":{"line":182,"column":1},"end":{"line":182,"column":1}},"children":[{"type":"text","value":"In the field we inject current through two ","position":{"start":{"line":182,"column":1},"end":{"line":182,"column":1}},"key":"qXP3lcDRho"},{"type":"strong","position":{"start":{"line":182,"column":1},"end":{"line":182,"column":1}},"children":[{"type":"text","value":"current electrodes","position":{"start":{"line":182,"column":1},"end":{"line":182,"column":1}},"key":"yZGlftuCRm"}],"key":"Vw1c6qOleV"},{"type":"text","value":" (A, B) and measure voltage across two ","position":{"start":{"line":182,"column":1},"end":{"line":182,"column":1}},"key":"U96xwNs2iu"},{"