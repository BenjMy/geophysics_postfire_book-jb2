y_sub = y_rast[::step]
z_sub = z_grid[::step, ::step]
XX, YY = np.meshgrid(x_sub, y_sub)

# Interpolate elevation at survey points
interp_func = RegularGridInterpolator(
    (y_rast[::-1], x_rast), z_grid[::-1, :],
    bounds_error=False, fill_value=0
)
